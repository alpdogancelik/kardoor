---
import { collections } from "../data/collections";
import DoorVisual from "./DoorVisual.astro";

const slideCount = collections.length;
---

<section
  id="koleksiyonlar"
  class="collection-showcase"
  data-collection-carousel
  data-home-showroom-content
  style={`--slide-count:${slideCount};`}
>
  <div class="collection-showcase-stage" data-carousel-stage>
    <div class="showcase-progress" aria-hidden="true">
      <span data-carousel-progress></span>
    </div>

    <div class="collection-showcase-track" data-carousel-track>
      {
        collections.map((collection, index) => {
          const previous =
            collections[(index - 1 + collections.length) % collections.length];

          const next = collections[(index + 1) % collections.length];

          return (
            <article
              class="showcase-slide"
              data-carousel-slide
              style={`--room-accent:${collection.accentColor};`}
            >
              <div class="showcase-bg" aria-hidden="true"></div>

              <div class="showcase-lamp" aria-hidden="true">
                <span></span>
              </div>

              <div class="showcase-ghost showcase-ghost-left" aria-hidden="true">
                {previous.shortTitle}
              </div>

              <div class="showcase-ghost showcase-ghost-right" aria-hidden="true">
                {next.shortTitle}
              </div>

              <div class="showcase-side-door showcase-side-door-left" aria-hidden="true">
                <DoorVisual
                  image={previous.image}
                  alt=""
                  size="spotlight"
                  className="showcase-side-door-visual"
                />
              </div>

              <div class="showcase-side-door showcase-side-door-right" aria-hidden="true">
                <DoorVisual
                  image={next.image}
                  alt=""
                  size="spotlight"
                  className="showcase-side-door-visual"
                />
              </div>

              <div class="showcase-center">
                <p class="showcase-number">
                  KOLEKSİYON {collection.number}
                </p>

                <h2 class="kardoor-display showcase-title">
                  {collection.shortTitle}
                </h2>

                <div class="showcase-door-stage">
                  <div class="showcase-door-halo" aria-hidden="true"></div>

                  <DoorVisual
                    image={collection.image}
                    alt={collection.title}
                    size="portal"
                    className="showcase-main-door"
                  />

                  <div class="showcase-ring" aria-hidden="true"></div>
                </div>

                <div class="showcase-actions">
                  <a href={`/koleksiyonlar/${collection.slug}`} class="showcase-btn showcase-btn-secondary">
                    Seriyi İncele
                  </a>

                  <a href="/teklif" class="showcase-btn showcase-btn-primary">
                    Teklif Al
                  </a>

                  <a href="/urunler" class="showcase-btn showcase-btn-icon" aria-label="Ürünleri gör">
                    +
                  </a>
                </div>
              </div>

              <aside class="showcase-info">
                <p>{collection.description}</p>

                <ul>
                  {collection.modelCodes.map((code) => (
                    <li>{code}</li>
                  ))}
                </ul>
              </aside>
            </article>
          );
        })
      }
    </div>
  </div>

  <style>
    .collection-showcase {
      position: relative;
      background: #02060b;
      overflow: hidden;
    }

    .collection-showcase-stage {
      position: relative;
      height: 100svh;
      overflow: hidden;
      background:
        radial-gradient(circle at 50% 26%, rgba(255, 255, 255, 0.08), transparent 23%),
        linear-gradient(180deg, rgba(107, 114, 128, 0.08), transparent 42%),
        linear-gradient(180deg, #02060b 0%, #050b10 100%);
      isolation: isolate;
    }

    .collection-showcase-track {
      position: relative;
      z-index: 2;
      display: flex;
      width: max-content;
      height: 100%;
      will-change: transform;
    }

    .showcase-slide {
      position: relative;
      flex: 0 0 100vw;
      width: 100vw;
      height: 100svh;
      overflow: hidden;
      isolation: isolate;
      background: #02060b;
    }

    .showcase-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(circle at 50% 34%, color-mix(in srgb, var(--room-accent), transparent 88%), transparent 26%),
        linear-gradient(180deg, rgba(107, 114, 128, 0.08), transparent 42%),
        linear-gradient(90deg, rgba(255, 255, 255, 0.035), transparent 18%, transparent 82%, rgba(255, 255, 255, 0.035));
    }

    .showcase-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at center, transparent 36%, rgba(0, 0, 0, 0.42)),
        linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.36));
    }

    .showcase-lamp {
      position: absolute;
      z-index: 8;
      top: var(--header-height);
      left: 50%;
      width: min(280px, 22vw);
      height: 160px;
      transform: translateX(-50%);
      display: grid;
      place-items: start center;
      pointer-events: none;
    }

    .showcase-lamp span {
      width: min(230px, 18vw);
      height: 88px;
      border-radius: 0 0 50% 50%;
      background:
        radial-gradient(ellipse at 50% 100%, rgba(255, 255, 255, 0.95), transparent 34%),
        linear-gradient(180deg, #181a1d, #050506);
      filter: drop-shadow(0 28px 55px rgba(255, 255, 255, 0.18));
      opacity: 0.96;
    }

    .showcase-lamp::after {
      content: "";
      position: absolute;
      top: 72px;
      left: 50%;
      width: min(720px, 52vw);
      height: min(560px, 58vh);
      transform: translateX(-50%);
      background: radial-gradient(ellipse at 50% 0%, rgba(255, 255, 255, 0.18), transparent 65%);
      filter: blur(18px);
      opacity: 0.88;
    }

    .showcase-center {
      position: absolute;
      z-index: 5;
      inset: var(--header-height) 0 0;
      display: grid;
      place-items: center;
      pointer-events: none;
    }

    .showcase-number {
      position: absolute;
      top: 17%;
      left: 50%;
      margin: 0;
      transform: translateX(-50%);
      color: var(--room-accent);
      font-size: 0.82rem;
      font-weight: 900;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-align: center;
    }

    .showcase-title {
      position: absolute;
      z-index: 8;
      left: 50%;
      top: 45%;
      width: min(1000px, 88vw);
      margin: 0;
      transform: translate(-50%, -50%);
      color: rgba(237, 243, 250, 0.92);
      font-size: clamp(5rem, 11vw, 12.5rem);
      line-height: 0.82;
      text-align: center;
      letter-spacing: 0.01em;
      text-shadow: 0 18px 60px rgba(0, 0, 0, 0.62);
      pointer-events: none;
      mix-blend-mode: screen;
    }

    .showcase-door-stage {
      position: relative;
      z-index: 6;
      display: grid;
      place-items: center;
      min-width: min(640px, 70vw);
      min-height: min(700px, 70vh);
      pointer-events: none;
    }

    .showcase-door-halo {
      position: absolute;
      width: min(620px, 64vw);
      height: min(620px, 64vw);
      border-radius: 50%;
      background:
        radial-gradient(circle, color-mix(in srgb, var(--room-accent), transparent 74%), transparent 58%),
        radial-gradient(circle, rgba(255, 255, 255, 0.13), transparent 44%);
      filter: blur(30px);
      opacity: 0.9;
    }

    .showcase-main-door {
      position: relative;
      z-index: 7;
    }

    .showcase-main-door :global(.door-visual-image) {
      width: min(390px, 34vw);
      filter:
        drop-shadow(0 40px 58px rgba(0, 0, 0, 0.78))
        drop-shadow(0 0 36px color-mix(in srgb, var(--room-accent), transparent 76%));
    }

    .showcase-main-door :global(.door-visual-reflection) {
      width: min(370px, 32vw);
      opacity: 0.18;
      filter: blur(8px);
    }

    .showcase-ring {
      position: absolute;
      z-index: 3;
      bottom: 7.5rem;
      left: 50%;
      width: min(760px, 58vw);
      height: 105px;
      border: 1px solid color-mix(in srgb, var(--room-accent), transparent 35%);
      border-radius: 50%;
      transform: translateX(-50%);
      box-shadow:
        0 0 30px color-mix(in srgb, var(--room-accent), transparent 76%),
        inset 0 0 35px rgba(255, 255, 255, 0.04);
    }

    .showcase-actions {
      position: absolute;
      z-index: 12;
      bottom: 2rem;
      left: 50%;
      display: flex;
      align-items: center;
      gap: 0.55rem;
      transform: translateX(-50%);
      padding: 0.55rem;
      border: 1px solid rgba(255, 255, 255, 0.13);
      border-radius: 8px;
      background: rgba(7, 9, 12, 0.78);
      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.42);
      backdrop-filter: blur(14px);
      pointer-events: auto;
    }

    .showcase-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      border-radius: 8px;
      padding: 0.8rem 1.4rem;
      font-size: 0.82rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background 180ms ease;
    }

    .showcase-btn:hover {
      transform: translateY(-1px);
    }

    .showcase-btn-primary {
      border: 1px solid var(--room-accent);
      background: var(--room-accent);
      color: #02060b;
    }

    .showcase-btn-secondary,
    .showcase-btn-icon {
      border: 1px solid rgba(237, 243, 250, 0.48);
      background: rgba(8, 13, 19, 0.72);
      color: #edf3fa;
    }

    .showcase-btn-icon {
      width: 50px;
      padding: 0;
      font-size: 1.2rem;
    }

    .showcase-side-door {
      position: absolute;
      z-index: 2;
      top: 30%;
      width: min(260px, 18vw);
      opacity: 0.44;
      filter: grayscale(0.4);
    }

    .showcase-side-door-left {
      left: 12%;
    }

    .showcase-side-door-right {
      right: 12%;
    }

    .showcase-side-door :global(.door-visual-image) {
      width: min(250px, 17vw);
      filter: drop-shadow(0 24px 40px rgba(0, 0, 0, 0.7));
    }

    .showcase-side-door :global(.door-visual-reflection) {
      opacity: 0.14;
    }

    .showcase-ghost {
      position: absolute;
      z-index: 3;
      top: 46%;
      transform: translateY(-50%);
      max-width: 36vw;
      color: rgba(237, 243, 250, 0.12);
      font-family: "Bebas Neue", sans-serif;
      font-size: clamp(4.6rem, 8vw, 9.5rem);
      line-height: 0.86;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      white-space: nowrap;
      pointer-events: none;
      -webkit-text-stroke: 1px rgba(237, 243, 250, 0.16);
    }

    .showcase-ghost-left {
      left: 4%;
    }

    .showcase-ghost-right {
      right: 4%;
    }

    .showcase-info {
      position: absolute;
      z-index: 11;
      left: max(2rem, calc((100vw - 1420px) / 2));
      bottom: clamp(2rem, 5vw, 4rem);
      width: min(430px, 32vw);
      pointer-events: auto;
    }

    .showcase-info p {
      margin: 0;
      color: rgba(220, 232, 243, 0.82);
      font-size: clamp(0.95rem, 1.08vw, 1.08rem);
      line-height: 1.65;
    }

    .showcase-info ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin: 1rem 0 0;
      padding: 0;
      list-style: none;
    }

    .showcase-info li {
      border: 1px solid rgba(237, 243, 250, 0.22);
      border-radius: 999px;
      padding: 0.35rem 0.62rem;
      background: rgba(3, 8, 14, 0.72);
      color: #edf3fa;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .showcase-progress {
      position: absolute;
      z-index: 30;
      right: 1.4rem;
      top: 50%;
      width: 4px;
      height: min(280px, 44vh);
      transform: translateY(-50%);
      border-radius: 999px;
      background: rgba(237, 243, 250, 0.16);
      overflow: hidden;
    }

    .showcase-progress span {
      display: block;
      width: 100%;
      height: 100%;
      transform: scaleY(0);
      transform-origin: top center;
      border-radius: inherit;
      background: var(--accent);
      box-shadow: 0 0 24px rgba(44, 227, 255, 0.7);
      will-change: transform;
    }

    .showcase-slide:not(.is-active) .showcase-title,
    .showcase-slide:not(.is-active) .showcase-info,
    .showcase-slide:not(.is-active) .showcase-actions {
      opacity: 0.25;
    }

    @media (max-width: 1100px) {
      .collection-showcase-stage {
        height: auto;
        min-height: 100svh;
      }

      .collection-showcase-track {
        display: grid;
        width: 100%;
      }

      .showcase-slide {
        width: 100%;
        height: auto;
        min-height: 100svh;
        padding-top: var(--header-height);
      }

      .showcase-title {
        font-size: clamp(4rem, 14vw, 7.5rem);
      }

      .showcase-info {
        left: 1rem;
        right: 1rem;
        bottom: 7rem;
        width: auto;
      }

      .showcase-side-door,
      .showcase-ghost {
        display: none;
      }

      .showcase-main-door :global(.door-visual-image) {
        width: min(330px, 68vw);
      }

      .showcase-ring {
        width: min(560px, 82vw);
      }

      .showcase-progress {
        display: none;
      }
    }

    @media (max-width: 760px) {
      .showcase-number {
        top: 13%;
      }

      .showcase-title {
        top: 42%;
        font-size: clamp(3.2rem, 16vw, 5.3rem);
      }

      .showcase-door-stage {
        min-height: 620px;
      }

      .showcase-actions {
        width: calc(100% - 1rem);
        justify-content: center;
        bottom: 1rem;
      }

      .showcase-btn {
        min-height: 44px;
        padding: 0.72rem 0.95rem;
        font-size: 0.7rem;
      }

      .showcase-info {
        bottom: 6rem;
      }
    }
  </style>
</section>
