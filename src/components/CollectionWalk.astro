---
import { collections } from "../data/collections";
import CollectionRoom from "./CollectionRoom.astro";
---

<section class="collection-walk" data-collection-walk>
  <div class="collection-walk-intro" data-reveal>
    <p class="kardoor-kicker">KOLEKSİYON ODALARI</p>

    <h2 class="kardoor-display" data-split>
      Kapı Kapı Keşfedin
    </h2>

    <p>
      Kardoor serileri klasik katalog kartları olarak değil, showroom içinde
      ayrı karaktere sahip kapı sahneleri olarak sunulur.
    </p>
  </div>

  <div class="collection-track" data-collection-track>
    {collections.map((collection) => <CollectionRoom collection={collection} />)}
  </div>
</section>