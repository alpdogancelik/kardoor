---
const steps = [
  "Seri seç",
  "Model seç",
  "Ölçü / kullanım alanı belirt",
  "İletişim bilgilerini gönder"
];
---

<section class="section-shell">
  <div class="site-container space-y-8">
    <div class="space-y-3" data-reveal>
      <p class="kardoor-kicker">Teklif Akışı</p>
      <h2 class="kardoor-display text-4xl text-white sm:text-5xl">Kapınızı 4 Adımda Netleştirelim</h2>
      <p class="max-w-2xl text-slate-300">
        Karmaşık formlar yerine, karar sürecini sadeleştiren hızlı bir yönlendirme ile teklif sürecini başlatın.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((step, index) => (
          <article class="panel p-5" data-reveal data-reveal-delay={String(index * 0.05)}>
            <p class="text-xs uppercase tracking-[0.15em] text-accent-400">Adım {index + 1}</p>
            <h3 class="mt-3 text-xl font-semibold text-white">{step}</h3>
          </article>
        ))
      }
    </div>
  </div>
</section>
