<section class="corridor-scene" data-showroom-corridor>
  <div class="corridor-scene-bg" aria-hidden="true"></div>
  <div class="corridor-scene-grid" aria-hidden="true"></div>
  <div class="corridor-scene-vignette" aria-hidden="true"></div>

  <div class="corridor-shell">
    <div class="corridor-copy" data-reveal>
      <p class="kardoor-kicker">SHOWROOM CORRIDOR</p>

      <h2 class="kardoor-display" data-split>
        Koleksiyonlar Arasında Yürüyün
      </h2>

      <p>
        Kapıdan içeri girdikten sonra Kardoor koleksiyonları ayrı showroom
        odaları gibi açılır. Her seri; yüzey, kasa, kanat ve kullanım karakterine
        göre kendi atmosferinde sunulur.
      </p>

      <div class="corridor-path-list" aria-label="Showroom akışı">
        <div>
          <strong>01</strong>
          <span>Showroom koridoruna giriş</span>
        </div>

        <div>
          <strong>02</strong>
          <span>Seri karakterlerini karşılaştırma</span>
        </div>

        <div>
          <strong>03</strong>
          <span>Model ve teklif akışına geçiş</span>
        </div>
      </div>
    </div>

    <div class="corridor-visual" aria-hidden="true" data-reveal>
      <div class="corridor-perspective-room">
        <div class="corridor-ceiling">
          <span></span>
        </div>

        <div class="corridor-side-wall corridor-side-wall-left"></div>
        <div class="corridor-side-wall corridor-side-wall-right"></div>

        <div class="corridor-display-zone corridor-display-zone-left">
          <span></span>
        </div>

        <div class="corridor-display-zone corridor-display-zone-right">
          <span></span>
        </div>

        <div class="corridor-vanishing-door">
          <span class="corridor-door-line corridor-door-line-left"></span>
          <span class="corridor-door-line corridor-door-line-center"></span>
          <span class="corridor-door-handle"></span>
        </div>

        <div class="corridor-floor-plane"></div>
        <div class="corridor-axis-line"></div>
        <div class="corridor-wayfinding-dot"></div>
        <div class="corridor-glow"></div>
      </div>

      <div class="corridor-room-label corridor-room-label-left">
        ALÜMİNYUM
      </div>

      <div class="corridor-room-label corridor-room-label-right">
        LAMİNOKS
      </div>

      <div class="corridor-room-label corridor-room-label-bottom">
        KOLEKSİYON ROTASI
      </div>
    </div>
  </div>

  <style>
    .corridor-scene {
      position: relative;
      min-height: 100svh;
      padding-top: calc(var(--header-height) + clamp(5rem, 9vw, 8rem));
      padding-bottom: clamp(5rem, 9vw, 8rem);
      overflow: hidden;
      isolation: isolate;
      background:
        radial-gradient(circle at 62% 42%, rgba(44, 227, 255, 0.13), transparent 34%),
        radial-gradient(circle at 50% 86%, rgba(255, 184, 107, 0.08), transparent 40%),
        linear-gradient(180deg, #050b10 0%, #07111a 58%, #050b10 100%);
    }

    .corridor-scene-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(2, 7, 12, 0.76), transparent 26%, transparent 74%, rgba(2, 7, 12, 0.78)),
        radial-gradient(circle at 66% 52%, rgba(44, 227, 255, 0.14), transparent 32%);
      opacity: 1;
    }

    .corridor-scene-grid {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(44, 227, 255, 0.038) 1px, transparent 1px),
        linear-gradient(180deg, rgba(44, 227, 255, 0.024) 1px, transparent 1px);
      background-size: 170px 170px;
      mask-image: radial-gradient(circle at 64% 48%, black, transparent 78%);
      opacity: 0.55;
    }

    .corridor-scene-vignette {
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      background:
        linear-gradient(180deg, rgba(5, 11, 16, 0.22), transparent 24%, transparent 72%, rgba(5, 11, 16, 0.72)),
        radial-gradient(circle at center, transparent 44%, rgba(0, 0, 0, 0.42));
    }

    .corridor-shell {
      position: relative;
      z-index: 4;
      width: min(1320px, calc(100% - 2rem));
      min-height: calc(100svh - var(--header-height));
      margin-inline: auto;
      display: grid;
      grid-template-columns: minmax(0, 0.78fr) minmax(560px, 1.22fr);
      gap: clamp(2rem, 5vw, 5.5rem);
      align-items: center;
    }

    .corridor-copy {
      max-width: 690px;
    }

    .corridor-copy h2 {
      margin: 0.45rem 0 0;
      font-size: clamp(3.7rem, 7vw, 7.6rem);
      line-height: 0.86;
      letter-spacing: 0.012em;
    }

    .corridor-copy > p:not(.kardoor-kicker) {
      margin: 1rem 0 0;
      max-width: 610px;
      color: var(--text-muted);
      font-size: clamp(1rem, 1.35vw, 1.15rem);
      line-height: 1.72;
    }

    .corridor-path-list {
      display: grid;
      gap: 0.72rem;
      margin-top: 1.45rem;
    }

    .corridor-path-list div {
      border: 1px solid rgba(138, 166, 190, 0.24);
      border-radius: 1rem;
      padding: 0.9rem 1rem;
      background: rgba(4, 10, 17, 0.56);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.75rem;
      align-items: center;
      backdrop-filter: blur(10px);
    }

    .corridor-path-list strong {
      color: var(--accent);
      font-size: 0.82rem;
      letter-spacing: 0.14em;
    }

    .corridor-path-list span {
      color: #dce8f3;
      font-size: 0.92rem;
      font-weight: 800;
    }

    .corridor-visual {
      position: relative;
      min-height: 650px;
      border: 1px solid rgba(138, 166, 190, 0.24);
      border-radius: 1.75rem;
      overflow: hidden;
      isolation: isolate;
      background:
        radial-gradient(circle at 50% 72%, rgba(44, 227, 255, 0.14), transparent 36%),
        linear-gradient(180deg, rgba(8, 16, 26, 0.94), rgba(2, 6, 11, 0.96));
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.46),
        0 32px 100px rgba(0, 0, 0, 0.28);
    }

    .corridor-visual::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.045), transparent 20%, transparent 80%, rgba(255, 255, 255, 0.035)),
        linear-gradient(180deg, rgba(44, 227, 255, 0.055), transparent 44%);
      opacity: 0.9;
    }

    .corridor-perspective-room {
      position: absolute;
      inset: 0;
      z-index: 2;
      perspective: 900px;
      overflow: hidden;
    }

    .corridor-ceiling {
      position: absolute;
      left: 16%;
      right: 16%;
      top: 15%;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255, 184, 107, 0.58), transparent);
      box-shadow: 0 0 28px rgba(255, 184, 107, 0.22);
    }

    .corridor-ceiling span {
      position: absolute;
      left: 50%;
      top: -2px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      transform: translateX(-50%);
      background: rgba(255, 184, 107, 0.8);
      box-shadow: 0 0 30px rgba(255, 184, 107, 0.44);
    }

    .corridor-side-wall {
      position: absolute;
      top: 15%;
      bottom: 12%;
      width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(44, 227, 255, 0.48), transparent);
      opacity: 0.9;
    }

    .corridor-side-wall-left {
      left: 25%;
      transform: skewX(-18deg);
      transform-origin: bottom center;
    }

    .corridor-side-wall-right {
      right: 25%;
      transform: skewX(18deg);
      transform-origin: bottom center;
    }

    .corridor-display-zone {
      position: absolute;
      top: 28%;
      width: 116px;
      height: 248px;
      border: 1px solid rgba(44, 227, 255, 0.18);
      border-radius: 0.95rem;
      background: rgba(5, 12, 20, 0.56);
      display: grid;
      place-items: center;
      opacity: 0.78;
      box-shadow:
        inset 0 0 34px rgba(0, 0, 0, 0.34),
        0 0 42px rgba(44, 227, 255, 0.055);
    }

    .corridor-display-zone span {
      width: 44px;
      height: 148px;
      border-radius: 0.45rem;
      background:
        linear-gradient(160deg, rgba(44, 227, 255, 0.18), rgba(255, 255, 255, 0.045)),
        #111d29;
      box-shadow: 0 0 30px rgba(44, 227, 255, 0.08);
    }

    .corridor-display-zone-left {
      left: 9%;
      transform: perspective(900px) rotateY(30deg) scale(0.9);
    }

    .corridor-display-zone-right {
      right: 9%;
      transform: perspective(900px) rotateY(-30deg) scale(0.9);
    }

    .corridor-vanishing-door {
      position: absolute;
      left: 50%;
      top: 30%;
      width: 138px;
      height: 218px;
      border: 1px solid rgba(220, 232, 243, 0.18);
      border-radius: 0.85rem;
      transform: translateX(-50%) scale(0.9);
      background:
        linear-gradient(160deg, #263645, #111a24 56%, #071019);
      box-shadow:
        0 24px 60px rgba(0, 0, 0, 0.3),
        0 0 50px rgba(44, 227, 255, 0.09);
    }

    .corridor-door-line {
      position: absolute;
      top: 31px;
      bottom: 27px;
      border-radius: 999px;
      background: rgba(44, 227, 255, 0.18);
    }

    .corridor-door-line-left {
      left: 29px;
      width: 8px;
    }

    .corridor-door-line-center {
      left: 56px;
      width: 5px;
      background: rgba(220, 232, 243, 0.16);
    }

    .corridor-door-handle {
      position: absolute;
      top: 64px;
      right: 27px;
      width: 10px;
      height: 104px;
      border-radius: 999px;
      background: #dce8f3;
      box-shadow: 0 0 20px rgba(220, 232, 243, 0.28);
    }

    .corridor-floor-plane {
      position: absolute;
      left: 11%;
      right: 11%;
      bottom: 9%;
      height: 50%;
      border: 1px solid rgba(44, 227, 255, 0.14);
      border-top-color: rgba(255, 184, 107, 0.2);
      transform: perspective(840px) rotateX(62deg);
      transform-origin: bottom center;
      background:
        linear-gradient(90deg, transparent 0 49.8%, rgba(44, 227, 255, 0.26) 49.8% 50.2%, transparent 50.2% 100%),
        radial-gradient(circle at 50% 100%, rgba(44, 227, 255, 0.12), transparent 56%),
        radial-gradient(circle at 50% 38%, rgba(255, 184, 107, 0.11), transparent 48%);
    }

    .corridor-axis-line {
      position: absolute;
      top: 16%;
      bottom: 8%;
      left: 50%;
      width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(44, 227, 255, 0.66), transparent);
      box-shadow: 0 0 20px rgba(44, 227, 255, 0.28);
    }

    .corridor-wayfinding-dot {
      position: absolute;
      left: 50%;
      top: 53%;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      transform: translate(-50%, -50%);
      background: var(--accent);
      box-shadow: 0 0 30px rgba(44, 227, 255, 0.76);
    }

    .corridor-glow {
      position: absolute;
      left: 50%;
      bottom: 9%;
      width: 66%;
      height: 150px;
      transform: translateX(-50%);
      border-radius: 50%;
      background: radial-gradient(circle, rgba(44, 227, 255, 0.2), transparent 68%);
      filter: blur(16px);
    }

    .corridor-room-label {
      position: absolute;
      z-index: 4;
      border: 1px solid rgba(44, 227, 255, 0.32);
      border-radius: 999px;
      padding: 0.44rem 0.72rem;
      background: rgba(3, 8, 14, 0.78);
      color: #dce8f3;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      backdrop-filter: blur(10px);
      box-shadow: 0 0 22px rgba(44, 227, 255, 0.08);
    }

    .corridor-room-label-left {
      left: 8%;
      top: 18%;
    }

    .corridor-room-label-right {
      right: 8%;
      top: 18%;
    }

    .corridor-room-label-bottom {
      left: 50%;
      bottom: 7%;
      transform: translateX(-50%);
    }

    @media (max-width: 1100px) {
      .corridor-shell {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }

      .corridor-copy {
        max-width: 780px;
      }

      .corridor-visual {
        min-height: 540px;
      }
    }

    @media (max-width: 760px) {
      .corridor-shell {
        width: min(100% - 1rem, 1320px);
      }

      .corridor-copy h2 {
        font-size: clamp(3rem, 16vw, 4.8rem);
      }

      .corridor-visual {
        min-height: 430px;
        border-radius: 1.25rem;
      }

      .corridor-display-zone {
        display: none;
      }

      .corridor-room-label {
        display: none;
      }

      .corridor-vanishing-door {
        top: 27%;
        transform: translateX(-50%) scale(0.72);
      }

      .corridor-floor-plane {
        left: 4%;
        right: 4%;
        bottom: 7%;
      }
    }
  </style>
</section>