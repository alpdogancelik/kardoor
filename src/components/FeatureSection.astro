---
import { features } from "../data/features";
---

<section class="section-shell">
  <div class="site-container">
    <div class="panel p-6 sm:p-8 lg:p-10">
      <div class="mb-8 space-y-3" data-reveal>
        <p class="kardoor-kicker">Neden Kardoor</p>
        <h2 class="kardoor-display text-4xl text-white sm:text-5xl">Performans ve Prestij Bir Arada</h2>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        {
          features.map((feature, index) => (
            <article class="rounded-2xl border border-white/10 bg-showroom-900/70 p-5" data-reveal data-reveal-delay={String(index * 0.04)}>
              <h3 class="text-lg font-semibold text-white">{feature.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-300">{feature.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
