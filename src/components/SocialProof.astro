---
const socialCards = [
  {
    title: "Showroom",
    image: "https://images.unsplash.com/photo-1600210491369-e753d80a41f3?auto=format&fit=crop&w=1000&q=80"
  },
  {
    title: "Üretim",
    image: "https://images.unsplash.com/photo-1581092580497-e0d23cbdf1dc?auto=format&fit=crop&w=1000&q=80"
  },
  {
    title: "Montaj",
    image: "https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?auto=format&fit=crop&w=1000&q=80"
  },
  {
    title: "Detay",
    image: "https://images.unsplash.com/photo-1617104551722-3b2d51366496?auto=format&fit=crop&w=1000&q=80"
  }
];
---

<section class="section-shell">
  <div class="site-container space-y-8">
    <div class="space-y-3" data-reveal>
      <p class="kardoor-kicker">Sosyal Kanıt</p>
      <h2 class="kardoor-display text-4xl text-white sm:text-5xl">Proje Hikayelerinden Kesitler</h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        socialCards.map((item, index) => (
          <article class="panel overflow-hidden" data-reveal data-reveal-delay={String(index * 0.05)}>
            <div class="relative h-56">
              <img src={item.image} alt={item.title} class="h-full w-full object-cover" loading="lazy" />
              <div class="card-overlay absolute inset-0"></div>
              <p class="absolute bottom-3 left-3 rounded-full border border-white/20 bg-black/30 px-3 py-1 text-xs uppercase tracking-[0.12em] text-slate-100">
                {item.title}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
