<section
  id="door-transition"
  class="home-photo-hero"
  aria-label="Kardoor ana sayfa görseli"
  data-home-door-sequence
>
  <div class="home-photo-zoom-layer" data-home-zoom-layer>
  <img
    src="/images/Gemini_Generated_Image_k7lt3wk7lt3wk7lt.png"
    alt="Kardoor premium çelik kapı ana sayfa görseli"
    class="home-photo-hero-image"
    data-home-hero-image
    loading="eager"
    decoding="async"
  />

  <div
    class="home-door-sequence"
    data-door-sequence-stage
    aria-hidden="true"
  >
    <canvas
      class="home-door-sequence-frame"
      data-door-sequence-frame
    ></canvas>
  </div>
  </div>

  <div class="home-photo-actions" aria-label="Ana sayfa hızlı bağlantılar">
    <a href="#koleksiyonlar">Kapıdan Gir</a>
    <a href="/teklif">Teklif Al</a>
  </div>

  <div class="home-photo-portal-blackout" data-home-portal-blackout aria-hidden="true"></div>

  <style>
    .home-photo-hero {
      position: relative;
      min-height: 100svh;
      margin-top: calc(var(--header-height) * -1);
      overflow: hidden;
      isolation: isolate;
      background: #000;
    }

    .home-photo-zoom-layer {
      position: absolute;
      inset: 0;
      z-index: 1;
      overflow: hidden;
      transform-origin: var(--zoom-origin-x, 50%) var(--zoom-origin-y, 52%);
      transform: scale(var(--hero-zoom-scale, 1));
      filter: brightness(var(--hero-zoom-brightness, 1));
      will-change: transform, filter;
    }

    .home-photo-hero-image {
      position: absolute;
      inset: 0;
      z-index: 1;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    .home-door-sequence {
      position: absolute;
      z-index: 2;
      left: var(--door-left, 44%);
      top: var(--door-top, 25%);
      width: var(--door-width, 12%);
      height: var(--door-height, 44%);
      overflow: hidden;
      opacity: 1;
      pointer-events: none;
      clip-path: polygon(0.4% 0, 100% 0, 99.4% 100%, 0 100%);
      transform: translateZ(0);
      will-change: left, top, width, height;
    }

    .home-door-sequence-frame {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      max-width: none;
      height: 100%;
      filter: saturate(0.82) brightness(0.98) contrast(0.93);
      mix-blend-mode: normal;
      backface-visibility: hidden;
      transform: translateZ(0);
      will-change: opacity, transform;
    }

    .home-photo-actions {
      position: absolute;
      left: clamp(1.5rem, 4.1vw, 4.9rem);
      bottom: clamp(2.4rem, 5vh, 4.8rem);
      z-index: 3;
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    .home-photo-actions a {
      width: clamp(126px, 10.6vw, 203px);
      min-height: clamp(48px, 3vw, 58px);
      border-radius: 13px;
      opacity: 0;
    }

    .home-photo-portal-blackout {
      position: absolute;
      inset: 0;
      z-index: 4;
      pointer-events: none;
      opacity: var(--portal-blackout-opacity, 0);
      background:
        radial-gradient(
          circle at var(--zoom-origin-x, 50%) var(--zoom-origin-y, 52%),
          rgba(0, 0, 0, 0.94) 0%,
          rgba(0, 0, 0, 0.98) 38%,
          #000 74%
        );
      will-change: opacity;
    }

    @media (max-width: 900px) {
      .home-photo-hero {
        min-height: calc(100svh - 1px);
      }

      .home-photo-hero-image {
        object-position: 55% top;
      }

      .home-photo-actions {
        left: 1rem;
        bottom: 1.35rem;
      }

      .home-photo-actions a {
        width: 132px;
        min-height: 50px;
      }
    }
  </style>
</section>
