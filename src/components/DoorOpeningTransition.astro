---
import DoorVisual from "./DoorVisual.astro";
---

<section id="door-transition" class="door-entry-journey" data-showroom-journey>
  <div class="door-entry-fixed" data-journey-fixed>
    <div class="entry-bg" aria-hidden="true"></div>
    <div class="entry-grid" aria-hidden="true"></div>
    <div class="entry-vignette" aria-hidden="true"></div>

    <div class="entry-copy" data-journey-copy>
      <p class="kardoor-kicker">Kapıdan içeri girin</p>

      <h2 class="kardoor-display">Showroom Kapısı Açılıyor</h2>

      <p>
        Kardoor koleksiyonlarını sayfa aşağı kaydırılan klasik katalog gibi değil;
        kapıdan içeri girilen premium bir dijital showroom deneyimi olarak keşfedin.
      </p>

      <div class="entry-steps" aria-hidden="true">
        <span>01 Yaklaş</span>
        <span>02 Kapı açılsın</span>
        <span>03 İçeri gir</span>
      </div>
    </div>

    <div class="entry-portal" data-journey-portal>
      <div class="entry-light" data-door-light aria-hidden="true"></div>

      <div class="entry-depth" data-door-depth aria-hidden="true">
        <div class="depth-glow"></div>
        <div class="depth-ceiling"></div>
        <div class="depth-axis"></div>
        <div class="depth-line depth-line-left"></div>
        <div class="depth-line depth-line-right"></div>
        <div class="depth-floor"></div>
        <div class="depth-target"></div>
      </div>

      <div class="entry-frame" data-door-frame aria-hidden="true">
        <span></span>
      </div>

      <div class="entry-door" data-door-leaf>
        <DoorVisual
          image="/images/doors/door-midnight.svg"
          alt="Kardoor showroom giriş kapısı"
          size="portal"
        />
      </div>

      <div class="journey-label journey-label-left">Kasa</div>
      <div class="journey-label journey-label-right">Showroom</div>
      <div class="journey-label journey-label-bottom">İçeri geç</div>
    </div>

    <div class="entry-blackout" data-journey-blackout aria-hidden="true"></div>
  </div>

  <style>
    .door-entry-journey {
      position: relative;
      height: 100svh;
      background: #02060b;
      isolation: isolate;
      overflow: clip;
    }

    .door-entry-fixed {
      position: relative;
      height: 100svh;
      overflow: hidden;
      background: #02060b;
      isolation: isolate;
    }

    .entry-bg,
    .entry-grid,
    .entry-vignette,
    .entry-blackout {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .entry-bg {
      z-index: 0;
      background:
        radial-gradient(circle at 66% 48%, rgba(44, 227, 255, 0.2), transparent 34%),
        radial-gradient(circle at 50% 84%, rgba(255, 184, 107, 0.13), transparent 36%),
        linear-gradient(180deg, #050b10 0%, #07131d 58%, #02060b 100%);
    }

    .entry-grid {
      z-index: 1;
      opacity: 0.5;
      background:
        linear-gradient(90deg, rgba(44, 227, 255, 0.035) 1px, transparent 1px),
        linear-gradient(180deg, rgba(44, 227, 255, 0.025) 1px, transparent 1px);
      background-size: 150px 150px;
      mask-image: radial-gradient(circle at 63% 48%, black, transparent 78%);
    }

    .entry-vignette {
      z-index: 2;
      background:
        radial-gradient(circle at center, transparent 34%, rgba(0, 0, 0, 0.68)),
        linear-gradient(90deg, rgba(2, 6, 11, 0.12), transparent 40%, transparent 64%, rgba(2, 6, 11, 0.24));
    }

    .entry-blackout {
      z-index: 40;
      opacity: 0;
      background: #02060b;
    }

    .entry-copy {
      position: absolute;
      z-index: 9;
      left: max(2rem, calc((100vw - 1380px) / 2));
      top: 50%;
      width: min(610px, 43vw);
      transform: translateY(-50%);
      will-change: opacity, transform;
    }

    .entry-copy h2 {
      margin: 0.55rem 0 0;
      max-width: 610px;
      font-size: clamp(4rem, 7.7vw, 8.3rem);
      line-height: 0.84;
      letter-spacing: 0.01em;
    }

    .entry-copy p:not(.kardoor-kicker) {
      margin: 1rem 0 0;
      max-width: 570px;
      color: var(--text-muted);
      font-size: clamp(1rem, 1.28vw, 1.16rem);
      line-height: 1.72;
    }

    .entry-steps {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 1.2rem;
    }

    .entry-steps span {
      border: 1px solid rgba(138, 166, 190, 0.24);
      border-radius: 999px;
      padding: 0.42rem 0.74rem;
      background: rgba(4, 10, 17, 0.6);
      color: #dce8f3;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      backdrop-filter: blur(10px);
    }

    .entry-portal {
      position: absolute;
      z-index: 7;
      inset: var(--header-height) 0 0;
      display: grid;
      place-items: center;
      perspective: 1850px;
      transform-style: preserve-3d;
      will-change: opacity, transform;
    }

    .entry-light {
      position: absolute;
      z-index: 0;
      width: min(800px, 68vw);
      height: min(800px, 68vw);
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(255, 184, 107, 0.24), transparent 42%),
        radial-gradient(circle, rgba(44, 227, 255, 0.25), transparent 66%);
      filter: blur(34px);
      opacity: 0.42;
      transform: scale(0.92);
      will-change: opacity, transform;
    }

    .entry-depth {
      position: absolute;
      z-index: 1;
      width: min(590px, 62vw);
      height: min(730px, 76vh);
      border-radius: 1.8rem;
      overflow: hidden;
      opacity: 0;
      transform: scale(0.9);
      background:
        radial-gradient(circle at 50% 45%, rgba(255, 184, 107, 0.18), transparent 30%),
        linear-gradient(90deg, rgba(0, 0, 0, 0.58), transparent 28%, transparent 72%, rgba(0, 0, 0, 0.58)),
        linear-gradient(180deg, #1b2a36 0%, #08111a 54%, #04080d 100%);
      box-shadow:
        inset 0 0 120px rgba(0, 0, 0, 0.76),
        0 0 110px rgba(255, 184, 107, 0.13),
        0 0 96px rgba(44, 227, 255, 0.1);
      will-change: opacity, transform;
    }

    .depth-glow {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 45%, rgba(255, 184, 107, 0.22), transparent 38%),
        radial-gradient(circle at 50% 82%, rgba(44, 227, 255, 0.15), transparent 42%);
    }

    .depth-ceiling {
      position: absolute;
      top: 8%;
      left: 18%;
      right: 18%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255, 184, 107, 0.36), transparent);
    }

    .depth-axis {
      position: absolute;
      left: 50%;
      top: 12%;
      bottom: 9%;
      width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(44, 227, 255, 0.58), transparent);
      box-shadow: 0 0 24px rgba(44, 227, 255, 0.32);
    }

    .depth-line {
      position: absolute;
      top: 14%;
      bottom: 10%;
      width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(44, 227, 255, 0.44), transparent);
      transform-origin: bottom center;
    }

    .depth-line-left {
      left: 24%;
      transform: skewX(-18deg);
    }

    .depth-line-right {
      right: 24%;
      transform: skewX(18deg);
    }

    .depth-floor {
      position: absolute;
      left: 12%;
      right: 12%;
      bottom: 8%;
      height: 50%;
      border: 1px solid rgba(44, 227, 255, 0.13);
      border-top-color: rgba(255, 184, 107, 0.18);
      transform: perspective(900px) rotateX(62deg);
      transform-origin: bottom center;
      background:
        linear-gradient(90deg, transparent 0 49.8%, rgba(44, 227, 255, 0.26) 49.8% 50.2%, transparent 50.2% 100%),
        radial-gradient(circle at 50% 90%, rgba(255, 184, 107, 0.17), transparent 56%);
    }

    .depth-target {
      position: absolute;
      left: 50%;
      top: 31%;
      width: 118px;
      height: 164px;
      border: 1px solid rgba(255, 184, 107, 0.2);
      border-radius: 0.8rem;
      transform: translateX(-50%) scale(0.82);
      background:
        radial-gradient(circle at 50% 50%, rgba(255, 184, 107, 0.14), transparent 60%),
        rgba(5, 9, 14, 0.72);
    }

    .entry-frame {
      position: absolute;
      z-index: 3;
      width: min(490px, 58vw);
      height: min(700px, 76vh);
      border: 1px solid rgba(44, 227, 255, 0.28);
      border-radius: 1.5rem;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.09), transparent 22%, transparent 78%, rgba(255, 255, 255, 0.08)),
        rgba(7, 14, 22, 0.32);
      box-shadow:
        inset 0 0 90px rgba(0, 0, 0, 0.36),
        0 0 90px rgba(44, 227, 255, 0.11);
      will-change: opacity, transform;
    }

    .entry-frame span {
      position: absolute;
      inset: 8% 10%;
      border: 1px solid rgba(44, 227, 255, 0.16);
      border-radius: 1rem;
    }

    .entry-door {
      position: relative;
      z-index: 5;
      transform-origin: left center;
      transform-style: preserve-3d;
      will-change: opacity, transform;
    }

    .entry-door :global(.door-visual--portal .door-visual-image) {
      width: min(410px, 52vw);
      filter:
        drop-shadow(0 36px 44px rgba(0, 0, 0, 0.72))
        drop-shadow(0 0 28px rgba(44, 227, 255, 0.08));
    }

    .entry-door :global(.door-visual-reflection),
    .entry-door :global(.door-visual-floor-shadow) {
      opacity: 0;
    }

    .journey-label {
      position: absolute;
      z-index: 8;
      border: 1px solid rgba(44, 227, 255, 0.34);
      border-radius: 999px;
      padding: 0.44rem 0.72rem;
      background: rgba(3, 8, 14, 0.78);
      color: #dce8f3;
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      backdrop-filter: blur(10px);
    }

    .journey-label-left {
      left: 42%;
      top: 42%;
    }

    .journey-label-right {
      right: 12%;
      top: 35%;
    }

    .journey-label-bottom {
      left: 50%;
      bottom: 14%;
      transform: translateX(-50%);
    }

    @media (max-width: 900px) {
      .door-entry-journey {
        height: auto;
      }

      .door-entry-fixed {
        height: auto;
        min-height: 100svh;
        padding-top: var(--header-height);
      }

      .entry-copy,
      .entry-portal {
        position: relative;
        inset: auto;
        transform: none;
      }

      .entry-copy {
        width: min(760px, calc(100% - 2rem));
        margin: 3rem auto 0;
      }

      .entry-portal {
        min-height: 560px;
      }
    }

    @media (max-width: 760px) {
      .entry-copy h2 {
        font-size: clamp(3rem, 16vw, 4.6rem);
      }

      .entry-door :global(.door-visual--portal .door-visual-image) {
        width: min(300px, 72vw);
      }

      .journey-label {
        display: none;
      }
    }
  </style>
</section>
