---
import DoorVisual from "./DoorVisual.astro";
---

<section id="door-transition" class="door-entry-transition is-animated-portal" data-door-entry>
  <div class="door-entry-bg" aria-hidden="true"></div>
  <div class="door-entry-interior" data-door-interior aria-hidden="true"></div>

  <div class="door-entry-shell">
    <div class="door-entry-copy" data-door-copy data-reveal>
      <p class="kardoor-kicker">KAPIDAN İÇERİ GİRİN</p>

      <h2 class="kardoor-display" data-split>
        Showroom’a Hoş Geldiniz
      </h2>

      <p>
        Kardoor koleksiyonlarını, her serinin kendi karakterini taşıdığı premium
        bir dijital showroom deneyimi içinde keşfedin.
      </p>
    </div>

    <div class="door-entry-stage" data-door-stage data-reveal>
      <div class="door-entry-light" data-door-light aria-hidden="true"></div>
      <div class="door-entry-depth" data-door-depth aria-hidden="true"></div>
      <div class="door-entry-frame" data-door-frame aria-hidden="true"></div>

      <div class="door-entry-door" data-door-leaf>
        <DoorVisual
          image="/images/doors/door-midnight.svg"
          alt="Kardoor showroom giriş kapısı"
          size="portal"
        />
      </div>

      <div class="door-entry-floor" aria-hidden="true"></div>
    </div>
  </div>

  <style>
    .is-animated-portal {
      min-height: 100svh;
      padding: 0;
      display: grid;
      place-items: center;
      overflow: hidden;
      isolation: isolate;
    }

    .is-animated-portal .door-entry-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(circle at 66% 48%, rgba(44, 227, 255, 0.14), transparent 34%),
        radial-gradient(circle at 50% 100%, rgba(255, 184, 107, 0.16), transparent 40%),
        linear-gradient(180deg, #050b10 0%, #07111a 56%, #050b10 100%);
    }

    .is-animated-portal .door-entry-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(44, 227, 255, 0.05) 1px, transparent 1px),
        linear-gradient(180deg, rgba(44, 227, 255, 0.035) 1px, transparent 1px);
      background-size: 150px 150px;
      mask-image: radial-gradient(circle at 64% 50%, black, transparent 74%);
      opacity: 0.45;
    }

    .is-animated-portal .door-entry-interior {
      position: absolute;
      inset: 0;
      z-index: 1;
      opacity: 0;
      transform: scale(0.96);
      background:
        radial-gradient(circle at 64% 52%, rgba(255, 184, 107, 0.28), transparent 22%),
        linear-gradient(90deg, transparent 0 18%, rgba(44, 227, 255, 0.07) 18% 19%, transparent 19% 81%, rgba(44, 227, 255, 0.07) 81% 82%, transparent 82% 100%),
        linear-gradient(180deg, rgba(10, 20, 31, 0.16), rgba(5, 11, 18, 0.82));
    }

    .is-animated-portal .door-entry-shell {
      position: relative;
      z-index: 3;
      width: min(1240px, calc(100% - 2rem));
      min-height: 100svh;
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
      padding-top: var(--header-height);
    }

    .is-animated-portal .door-entry-copy {
      max-width: 620px;
    }

    .is-animated-portal .door-entry-copy h2 {
      margin: 0.45rem 0 0;
      font-size: clamp(3.4rem, 7vw, 7rem);
      line-height: 0.9;
    }

    .is-animated-portal .door-entry-copy p:not(.kardoor-kicker) {
      margin: 1rem 0 0;
      color: var(--text-muted);
      font-size: clamp(1rem, 1.4vw, 1.15rem);
      line-height: 1.65;
    }

    .is-animated-portal .door-entry-stage {
      position: relative;
      min-height: 640px;
      display: grid;
      place-items: center;
      perspective: 1400px;
      transform-style: preserve-3d;
      isolation: isolate;
      will-change: transform;
    }

    .is-animated-portal .door-entry-light {
      position: absolute;
      width: min(620px, 72vw);
      height: min(620px, 72vw);
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 184, 107, 0.42), transparent 66%);
      opacity: 0.35;
      filter: blur(28px);
      transform: translateX(7%) scale(0.9);
      will-change: transform, opacity;
    }

    .is-animated-portal .door-entry-depth {
      position: absolute;
      width: min(560px, 74vw);
      height: min(760px, 88vw);
      border-radius: 1.6rem;
      opacity: 0;
      transform: translateX(8%) scale(0.88);
      background:
        linear-gradient(90deg, rgba(0, 0, 0, 0.48), transparent 28%, transparent 72%, rgba(0, 0, 0, 0.5)),
        radial-gradient(circle at 50% 45%, rgba(255, 184, 107, 0.42), transparent 58%),
        linear-gradient(180deg, #14202b 0%, #050a10 100%);
      box-shadow:
        inset 0 0 80px rgba(0, 0, 0, 0.65),
        0 0 90px rgba(255, 184, 107, 0.18);
      will-change: transform, opacity;
    }

    .is-animated-portal .door-entry-frame {
      position: absolute;
      width: min(500px, 74vw);
      height: min(730px, 88vw);
      border: 1px solid rgba(44, 227, 255, 0.24);
      border-radius: 1.45rem;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 22%, transparent 78%, rgba(255, 255, 255, 0.08)),
        rgba(7, 14, 22, 0.42);
      transform: translateX(4%);
      box-shadow: 0 0 80px rgba(44, 227, 255, 0.08);
      will-change: transform, opacity;
    }

    .is-animated-portal .door-entry-door {
      position: relative;
      z-index: 3;
      transform-origin: left center;
      transform-style: preserve-3d;
      will-change: transform, opacity;
    }

    .is-animated-portal .door-entry-floor {
      position: absolute;
      bottom: 2.2rem;
      width: min(620px, 80vw);
      height: 140px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(44, 227, 255, 0.16), transparent 66%);
      filter: blur(12px);
      opacity: 0.9;
    }

    @media (max-width: 1023px) {
      .is-animated-portal .door-entry-shell {
        grid-template-columns: 1fr;
        gap: 0;
        padding-block: calc(var(--header-height) + 2rem) 3rem;
      }

      .is-animated-portal .door-entry-stage {
        min-height: 500px;
      }
    }

    @media (max-width: 760px) {
      .is-animated-portal .door-entry-shell {
        width: min(100% - 1rem, 1240px);
      }

      .is-animated-portal .door-entry-copy h2 {
        font-size: clamp(3rem, 16vw, 4.6rem);
      }

      .is-animated-portal .door-entry-stage {
        min-height: 430px;
      }
    }
  </style>
</section>