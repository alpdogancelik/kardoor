<section id="door-transition" class="door-transition" data-door-transition>
  <div class="door-transition-sticky">
    <div class="door-transition-interior" data-door-interior></div>

    <div class="door-transition-layout">
      <div class="door-transition-overlay" data-door-overlay>
        <p class="kardoor-kicker">Kapıdan İçeri Girin</p>
        <h2 class="kardoor-display" data-split>Kapıdan İçeri Girin</h2>
        <p>Kardoor koleksiyonlarını dijital showroom deneyimi içinde keşfedin.</p>
      </div>

      <div class="door-transition-camera" data-door-camera>
        <div class="portal-door-shell">
          <div class="portal-door-backlight" data-door-backlight></div>
          <div class="portal-door-leaf" data-door-leaf>
            <img src="/images/doors/door-midnight.svg" alt="Açılan Kardoor çelik kapı" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
