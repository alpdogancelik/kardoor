---
import DoorVisual from "./DoorVisual.astro";
---

<section class="entrance-portal" data-entrance-portal>
  <div class="entrance-portal-bg"></div>

  <div class="entrance-portal-door" data-reveal>
    <DoorVisual image="/images/doors/door-midnight.svg" alt="Kardoor premium çelik kapı" size="portal" />
  </div>

  <div class="entrance-portal-content" data-reveal>
    <p class="kardoor-kicker">PREMIUM ÇELİK KAPI SHOWROOMU</p>
    <h1 class="kardoor-display entrance-title" data-split>Girişinizin İlk İzlenimini Yeniden Tasarlayın</h1>
    <p class="entrance-subtitle">
      Güvenlik, estetik ve prestiji aynı çizgide buluşturan premium çelik kapı çözümleri.
    </p>
    <div class="entrance-actions">
      <a href="#door-transition" class="btn btn-primary">Showroom’a Gir</a>
      <a href="/teklif" class="btn btn-secondary">Teklif Al</a>
    </div>
  </div>
</section>
