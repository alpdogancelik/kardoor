---
import DoorVisual from "./DoorVisual.astro";
---

<section class="hero-portal" data-entrance-portal>
  <div class="hero-ambient" aria-hidden="true"></div>
  <div class="hero-gridlines" aria-hidden="true"></div>

  <div class="hero-shell">
    <div class="hero-copy" data-reveal>
      <p class="kardoor-kicker">PREMIUM ÇELİK KAPI SHOWROOMU</p>

      <h1 class="kardoor-display hero-title" data-split>
        Girişinizin İlk İzlenimini Yeniden Tasarlayın
      </h1>

      <p class="hero-description">
        Güvenlik, estetik ve prestiji aynı çizgide buluşturan premium çelik kapı
        çözümleri. Kardoor koleksiyonlarını dijital showroom deneyimiyle keşfedin.
      </p>

      <div class="hero-actions">
        <a href="#door-transition" class="btn btn-primary">Showroom’a Gir</a>
        <a href="/koleksiyonlar" class="btn btn-secondary">Koleksiyonları Keşfet</a>
      </div>

      <div class="hero-stats" aria-label="Kardoor öne çıkan değerler">
        <div>
          <strong>6</strong>
          <span>Premium Seri</span>
        </div>

        <div>
          <strong>18+</strong>
          <span>Model Kodu</span>
        </div>

        <div>
          <strong>Özel</strong>
          <span>Proje Desteği</span>
        </div>
      </div>
    </div>

    <div class="hero-stage" data-reveal>
      <div class="hero-stage-label hero-stage-label-top">K1001 / Signature Entry</div>
      <div class="hero-stage-label hero-stage-label-bottom">Çelik Gövde • Premium Yüzey • Çok Noktalı Kilit</div>

      <div class="hero-door-halo" aria-hidden="true"></div>
      <div class="hero-door-frame" aria-hidden="true"></div>
      <div class="hero-door-platform" aria-hidden="true"></div>

      <div class="hero-door-object">
        <DoorVisual
          image="/images/doors/door-midnight.svg"
          alt="Kardoor premium çelik giriş kapısı"
          size="portal"
        />
      </div>

      <div class="hero-callout hero-callout-left" aria-hidden="true">
        <span>Güvenlik</span>
      </div>

      <div class="hero-callout hero-callout-right" aria-hidden="true">
        <span>Yalıtım</span>
      </div>

      <div class="hero-callout hero-callout-bottom" aria-hidden="true">
        <span>Ölçüye Özel</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll-indicator" aria-hidden="true">
    <span></span>
    <p>Showroom’a gir</p>
  </div>

  <style>
    .hero-portal {
      position: relative;
      min-height: 100svh;
      padding-top: var(--header-height);
      overflow: hidden;
      isolation: isolate;
      background:
        radial-gradient(circle at 66% 45%, rgba(44, 227, 255, 0.16), transparent 34%),
        radial-gradient(circle at 18% 28%, rgba(255, 255, 255, 0.06), transparent 28%),
        linear-gradient(180deg, #050b10 0%, #07111a 62%, #050b10 100%);
    }

    .hero-ambient {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 66% 52%, rgba(44, 227, 255, 0.2), transparent 18%),
        linear-gradient(90deg, rgba(44, 227, 255, 0.05), transparent 20%, transparent 80%, rgba(44, 227, 255, 0.05));
      opacity: 0.9;
    }

    .hero-gridlines {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(44, 227, 255, 0.045) 1px, transparent 1px),
        linear-gradient(180deg, rgba(44, 227, 255, 0.03) 1px, transparent 1px);
      background-size: 160px 160px;
      mask-image: radial-gradient(circle at 66% 50%, black, transparent 74%);
      opacity: 0.55;
    }

    .hero-shell {
      position: relative;
      z-index: 3;
      width: min(1380px, calc(100% - 2rem));
      min-height: calc(100svh - var(--header-height));
      margin-inline: auto;
      display: grid;
      grid-template-columns: minmax(0, 0.82fr) minmax(480px, 1.18fr);
      gap: clamp(2rem, 5vw, 5.5rem);
      align-items: center;
    }

    .hero-copy {
      position: relative;
      z-index: 5;
      max-width: 720px;
    }

    .hero-title {
      margin: 0.65rem 0 0;
      font-size: clamp(4.2rem, 7.6vw, 8.8rem);
      line-height: 0.84;
      letter-spacing: 0.012em;
    }

    .hero-description {
      max-width: 620px;
      margin: 1.1rem 0 0;
      color: #c8d8e7;
      font-size: clamp(1rem, 1.35vw, 1.18rem);
      line-height: 1.72;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.45rem;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.65rem;
      max-width: 620px;
      margin-top: 1.8rem;
    }

    .hero-stats div {
      border: 1px solid rgba(138, 166, 190, 0.22);
      border-radius: 1rem;
      padding: 0.9rem;
      background: rgba(4, 10, 17, 0.46);
      backdrop-filter: blur(10px);
    }

    .hero-stats strong {
      display: block;
      color: white;
      font-size: clamp(1.35rem, 2.2vw, 2rem);
      line-height: 1;
    }

    .hero-stats span {
      display: block;
      margin-top: 0.35rem;
      color: var(--text-muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .hero-stage {
      position: relative;
      min-height: 680px;
      display: grid;
      place-items: center;
      isolation: isolate;
      perspective: 1400px;
    }

    .hero-door-halo {
      position: absolute;
      width: min(720px, 78vw);
      height: min(720px, 78vw);
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(44, 227, 255, 0.28), transparent 62%),
        radial-gradient(circle, rgba(255, 184, 107, 0.12), transparent 48%);
      filter: blur(34px);
      opacity: 0.92;
    }

    .hero-door-frame {
      position: absolute;
      width: min(540px, 72vw);
      height: min(760px, 88vw);
      border: 1px solid rgba(44, 227, 255, 0.22);
      border-radius: 1.55rem;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 20%, transparent 80%, rgba(255, 255, 255, 0.08)),
        rgba(6, 13, 21, 0.42);
      box-shadow:
        inset 0 0 80px rgba(0, 0, 0, 0.36),
        0 0 80px rgba(44, 227, 255, 0.08);
    }

    .hero-door-platform {
      position: absolute;
      bottom: 3.6rem;
      width: min(680px, 84vw);
      height: 150px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(44, 227, 255, 0.2), transparent 66%);
      filter: blur(12px);
      opacity: 0.95;
    }

    .hero-door-object {
      position: relative;
      z-index: 5;
      transform: translateY(-0.8rem);
    }

    .hero-door-object :global(.door-visual--portal .door-visual-image) {
      width: min(470px, 68vw);
    }

    .hero-door-object :global(.door-visual--portal .door-visual-reflection) {
      width: min(440px, 66vw);
      opacity: 0.22;
    }

    .hero-stage-label {
      position: absolute;
      z-index: 7;
      border: 1px solid rgba(44, 227, 255, 0.28);
      border-radius: 999px;
      background: rgba(3, 8, 14, 0.74);
      color: #dce8f3;
      padding: 0.48rem 0.72rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      backdrop-filter: blur(10px);
    }

    .hero-stage-label-top {
      top: 6.5rem;
      right: 8%;
    }

    .hero-stage-label-bottom {
      left: 5%;
      bottom: 6.4rem;
    }

    .hero-callout {
      position: absolute;
      z-index: 7;
      color: #dce8f3;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .hero-callout span {
      display: inline-flex;
      border: 1px solid rgba(44, 227, 255, 0.38);
      border-radius: 999px;
      padding: 0.44rem 0.7rem;
      background: rgba(3, 8, 14, 0.78);
      backdrop-filter: blur(10px);
    }

    .hero-callout-left {
      left: 8%;
      top: 34%;
    }

    .hero-callout-right {
      right: 6%;
      top: 42%;
    }

    .hero-callout-bottom {
      right: 18%;
      bottom: 18%;
    }

    .hero-scroll-indicator {
      position: absolute;
      left: 50%;
      bottom: 1.4rem;
      z-index: 8;
      display: grid;
      justify-items: center;
      gap: 0.45rem;
      transform: translateX(-50%);
      color: rgba(220, 232, 243, 0.7);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .hero-scroll-indicator span {
      width: 1px;
      height: 34px;
      background: linear-gradient(to bottom, transparent, var(--accent), transparent);
    }

    .hero-scroll-indicator p {
      margin: 0;
    }

    @media (max-width: 1100px) {
      .hero-shell {
        grid-template-columns: 1fr;
        gap: 0;
        padding-block: calc(var(--header-height) + 2rem) 4rem;
      }

      .hero-copy {
        max-width: 780px;
      }

      .hero-stage {
        min-height: 560px;
      }

      .hero-stage-label-top {
        top: 3rem;
      }
    }

    @media (max-width: 760px) {
      .hero-shell {
        width: min(100% - 1rem, 1380px);
      }

      .hero-title {
        font-size: clamp(3.2rem, 16vw, 4.8rem);
      }

      .hero-stats {
        grid-template-columns: 1fr;
      }

      .hero-stage {
        min-height: 460px;
      }

      .hero-door-object :global(.door-visual--portal .door-visual-image) {
        width: min(320px, 72vw);
      }

      .hero-door-object :global(.door-visual--portal .door-visual-reflection) {
        width: min(300px, 70vw);
      }

      .hero-stage-label,
      .hero-callout {
        display: none;
      }

      .hero-scroll-indicator {
        display: none;
      }
    }
  </style>
</section>