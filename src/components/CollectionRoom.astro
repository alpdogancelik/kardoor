---
import type { Collection } from "../data/collections";
import DoorVisual from "./DoorVisual.astro";
import TechnicalCallouts from "./TechnicalCallouts.astro";

interface Props {
  collection: Collection;
}

const { collection } = Astro.props;
---

<article
  class="collection-room"
  data-collection-room
  style={`--room-accent:${collection.accentColor};`}
>
  <div class="collection-room-content" data-reveal>
    <p class="collection-room-number">{collection.number}</p>

    <h3 class="kardoor-display collection-room-title" data-split>
      {collection.title}
    </h3>

    <p class="collection-room-description">
      {collection.description}
    </p>

    <ul class="collection-model-codes" aria-label={`${collection.title} model kodları`}>
      {collection.modelCodes.map((code) => <li>{code}</li>)}
    </ul>

    <div class="collection-room-actions">
      <a href={`/koleksiyonlar/${collection.slug}`} class="btn btn-primary">
        Seriyi İncele
      </a>

      <a href="/teklif" class="btn btn-secondary">
        Teklif Al
      </a>
    </div>
  </div>

  <div class="collection-room-visual" data-reveal>
    <div class="collection-room-light" aria-hidden="true"></div>
    <div class="collection-room-frame" aria-hidden="true"></div>

    <DoorVisual image={collection.image} alt={collection.title} size="room" />

    <TechnicalCallouts labels={collection.materials} />
  </div>
</article>