---
import DoorVisual from "./DoorVisual.astro";
import { products } from "../data/products";

const featuredCodes = ["K1001", "K1051", "K1101"];

const featured = featuredCodes
  .map((code) => products.find((item) => item.code === code))
  .filter((item): item is NonNullable<typeof item> => Boolean(item));
---

<section class="model-spotlight" data-featured-spotlight>
  <div class="model-spotlight-bg" aria-hidden="true"></div>

  <div class="model-spotlight-head" data-reveal>
    <p class="kardoor-kicker">FEATURED MODEL SPOTLIGHT</p>

    <h2 class="kardoor-display" data-split>
      Öne Çıkan Model Sahnesi
    </h2>

    <p>
      Kardoor’un öne çıkan modelleri; güvenlik, yüzey karakteri ve premium
      giriş etkisini tek sahnede birleştirir.
    </p>
  </div>

  <div class="model-stage-list">
    {featured.map((product, index) => (
      <article
        class:list={["model-stage", index % 2 === 1 && "model-stage-reverse"]}
        data-product-stage
      >
        <div class="model-stage-visual">
          <div class="model-stage-halo" aria-hidden="true"></div>
          <div class="model-stage-frame" aria-hidden="true"></div>
          <div class="model-stage-floor" aria-hidden="true"></div>

          <div class="model-stage-door">
            <DoorVisual image={product.image} alt={product.title} size="spotlight" />
          </div>

          <div class="model-stage-chip model-stage-chip-top" aria-hidden="true">
            {product.code}
          </div>

          <div class="model-stage-chip model-stage-chip-bottom" aria-hidden="true">
            {product.collection}
          </div>
        </div>

        <div class="model-stage-copy">
          <p class="model-stage-collection">{product.collection}</p>

          <h3 class="kardoor-display model-stage-code">
            {product.code}
          </h3>

          <p class="model-stage-description">
            {product.shortDescription}
          </p>

          <ul class="model-stage-specs" aria-label={`${product.code} teknik özellikleri`}>
            {product.specs.slice(0, 3).map((spec) => (
              <li>{spec}</li>
            ))}
          </ul>

          <div class="model-stage-actions">
            <a href={`/urunler/${product.slug}`} class="btn btn-secondary">
              Detayları Gör
            </a>

            <a href="/teklif" class="btn btn-primary">
              Teklif Al
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <style>
    .model-spotlight {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: clamp(5rem, 8vw, 8rem) 0;
      background:
        radial-gradient(circle at 24% 28%, rgba(44, 227, 255, 0.09), transparent 30%),
        radial-gradient(circle at 78% 68%, rgba(44, 227, 255, 0.08), transparent 36%),
        linear-gradient(180deg, #050b10 0%, #07111a 52%, #050b10 100%);
    }

    .model-spotlight-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(44, 227, 255, 0.04) 1px, transparent 1px),
        linear-gradient(180deg, rgba(44, 227, 255, 0.026) 1px, transparent 1px);
      background-size: 180px 180px;
      mask-image: radial-gradient(circle at 50% 45%, black, transparent 76%);
      opacity: 0.55;
    }

    .model-spotlight-head {
      position: relative;
      z-index: 2;
      width: min(1240px, calc(100% - 2rem));
      margin-inline: auto;
      margin-bottom: clamp(2rem, 5vw, 4rem);
    }

    .model-spotlight-head h2 {
      margin: 0.45rem 0 0;
      max-width: 920px;
      font-size: clamp(3.4rem, 7vw, 7rem);
      line-height: 0.9;
    }

    .model-spotlight-head p:not(.kardoor-kicker) {
      max-width: 700px;
      margin: 1rem 0 0;
      color: var(--text-muted);
      font-size: clamp(1rem, 1.35vw, 1.15rem);
      line-height: 1.7;
    }

    .model-stage-list {
      position: relative;
      z-index: 2;
      width: min(1240px, calc(100% - 2rem));
      margin-inline: auto;
      display: grid;
      gap: clamp(1.2rem, 2vw, 1.6rem);
    }

    .model-stage {
      position: relative;
      min-height: 640px;
      border: 1px solid rgba(138, 166, 190, 0.24);
      border-radius: 8px;
      padding: clamp(1.2rem, 3.4vw, 3rem);
      overflow: hidden;
      isolation: isolate;
      display: grid;
      grid-template-columns: minmax(380px, 0.86fr) minmax(0, 1.14fr);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
      background:
        radial-gradient(circle at 26% 54%, rgba(44, 227, 255, 0.12), transparent 34%),
        linear-gradient(160deg, rgba(10, 18, 30, 0.9), rgba(4, 8, 14, 0.94));
      box-shadow: 0 28px 90px rgba(0, 0, 0, 0.24);
    }

    .model-stage::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.04), transparent 20%, transparent 80%, rgba(255, 255, 255, 0.03)),
        linear-gradient(180deg, rgba(44, 227, 255, 0.04), transparent 38%);
      opacity: 0.8;
    }

    .model-stage-reverse {
      grid-template-columns: minmax(0, 1.14fr) minmax(380px, 0.86fr);
    }

    .model-stage-reverse .model-stage-visual {
      order: 2;
    }

    .model-stage-reverse .model-stage-copy {
      order: 1;
    }

    .model-stage-visual {
      position: relative;
      z-index: 2;
      min-height: 520px;
      display: grid;
      place-items: center;
      isolation: isolate;
    }

    .model-stage-halo {
      position: absolute;
      width: min(560px, 70vw);
      height: min(560px, 70vw);
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(44, 227, 255, 0.22), transparent 64%),
        radial-gradient(circle, rgba(107, 114, 128, 0.08), transparent 44%);
      filter: blur(30px);
    }

    .model-stage-frame {
      position: absolute;
      width: min(430px, 68vw);
      height: min(620px, 82vw);
      border: 1px solid rgba(44, 227, 255, 0.18);
      border-radius: 8px;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.07), transparent 20%, transparent 80%, rgba(255, 255, 255, 0.07)),
        rgba(6, 13, 21, 0.36);
      box-shadow:
        inset 0 0 70px rgba(0, 0, 0, 0.34),
        0 0 70px rgba(44, 227, 255, 0.08);
    }

    .model-stage-floor {
      position: absolute;
      bottom: 2.2rem;
      width: min(520px, 76vw);
      height: 125px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(44, 227, 255, 0.16), transparent 68%);
      filter: blur(11px);
    }

    .model-stage-door {
      position: relative;
      z-index: 5;
      transform: translateY(-0.5rem);
    }

    .model-stage-door :global(.door-visual--spotlight .door-visual-image) {
      width: min(350px, 58vw);
    }

    .model-stage-door :global(.door-visual--spotlight .door-visual-reflection) {
      width: min(330px, 56vw);
      opacity: 0.2;
    }

    .model-stage-chip {
      position: absolute;
      z-index: 8;
      border: 1px solid rgba(44, 227, 255, 0.3);
      border-radius: 999px;
      padding: 0.44rem 0.72rem;
      background: rgba(3, 8, 14, 0.76);
      color: #dce8f3;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      backdrop-filter: blur(10px);
    }

    .model-stage-chip-top {
      top: 4rem;
      left: 8%;
    }

    .model-stage-chip-bottom {
      right: 7%;
      bottom: 4.4rem;
    }

    .model-stage-copy {
      position: relative;
      z-index: 3;
      max-width: 620px;
    }

    .model-stage-collection {
      margin: 0;
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .model-stage-code {
      margin: 0.5rem 0 0;
      font-size: clamp(4rem, 7vw, 8rem);
      line-height: 0.86;
    }

    .model-stage-description {
      margin: 0.9rem 0 0;
      color: var(--text-muted);
      font-size: clamp(1rem, 1.35vw, 1.14rem);
      line-height: 1.72;
    }

    .model-stage-specs {
      display: grid;
      gap: 0.55rem;
      margin: 1.15rem 0 0;
      padding: 0;
      list-style: none;
    }

    .model-stage-specs li {
      border: 1px solid rgba(142, 168, 191, 0.28);
      border-radius: 8px;
      padding: 0.72rem 0.85rem;
      background: rgba(8, 14, 22, 0.7);
      color: #dce8f3;
      font-size: 0.92rem;
    }

    .model-stage-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.25rem;
    }

    @media (max-width: 1023px) {
      .model-stage,
      .model-stage-reverse {
        grid-template-columns: 1fr;
      }

      .model-stage-reverse .model-stage-visual,
      .model-stage-reverse .model-stage-copy {
        order: initial;
      }

      .model-stage {
        min-height: auto;
      }

      .model-stage-visual {
        min-height: 500px;
      }
    }

    @media (max-width: 760px) {
      .model-spotlight-head,
      .model-stage-list {
        width: min(100% - 1rem, 1240px);
      }

      .model-spotlight-head h2,
      .model-stage-code {
        font-size: clamp(3rem, 16vw, 4.8rem);
      }

      .model-stage {
        padding: 1rem;
        border-radius: 8px;
      }

      .model-stage-visual {
        min-height: 430px;
      }

      .model-stage-door :global(.door-visual--spotlight .door-visual-image) {
        width: min(310px, 72vw);
      }

      .model-stage-door :global(.door-visual--spotlight .door-visual-reflection) {
        width: min(290px, 70vw);
      }

      .model-stage-chip {
        display: none;
      }
    }
  </style>
</section>
