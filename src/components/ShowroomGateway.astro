---
import { collections } from "../data/collections";
import DoorVisual from "./DoorVisual.astro";

const entryCollection = collections[0];
---

<section class="showroom-gateway" data-home-showroom-content>
  <div class="showroom-gateway-bg" aria-hidden="true"></div>
  <div class="showroom-gateway-shade" aria-hidden="true"></div>

  <div class="showroom-gateway-door">
    <DoorVisual
      image={entryCollection.image}
      alt={entryCollection.title}
      size="portal"
      className="showroom-gateway-main-door"
    />
  </div>

  <div class="showroom-gateway-copy">
    <p>SHOWROOM</p>
    <h1>{entryCollection.shortTitle}</h1>
    <span>{entryCollection.description}</span>
  </div>

  <a href="#koleksiyonlar" class="showroom-gateway-action">Koleksiyonlara Geç</a>

  <style>
    .showroom-gateway {
      position: relative;
      min-height: 100svh;
      overflow: hidden;
      isolation: isolate;
      display: grid;
      place-items: center;
      background: #02060b;
      opacity: var(--showroom-content-opacity, 1);
      transform: scale(var(--showroom-content-scale, 1));
      transform-origin: center center;
      visibility: var(--showroom-content-visibility, visible);
    }

    .showroom-gateway-bg,
    .showroom-gateway-shade {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .showroom-gateway-bg {
      z-index: 0;
      background:
        radial-gradient(circle at 50% 36%, rgba(44, 227, 255, 0.16), transparent 24%),
        radial-gradient(circle at 50% 76%, rgba(255, 238, 72, 0.12), transparent 30%),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03), transparent 19%, transparent 81%, rgba(255, 255, 255, 0.025)),
        linear-gradient(180deg, #02060b 0%, #050b10 100%);
    }

    .showroom-gateway-shade {
      z-index: 4;
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.8), transparent 32%, rgba(0, 0, 0, 0.72) 100%),
        radial-gradient(circle at center, transparent 34%, rgba(0, 0, 0, 0.62) 100%);
    }

    .showroom-gateway-door {
      position: relative;
      z-index: 2;
      transform: translateY(2vh);
    }

    .showroom-gateway-main-door :global(.door-visual--portal .door-visual-image) {
      width: min(420px, 34vw);
      filter:
        drop-shadow(0 44px 70px rgba(0, 0, 0, 0.78))
        drop-shadow(0 0 42px rgba(44, 227, 255, 0.16));
    }

    .showroom-gateway-main-door :global(.door-visual-reflection) {
      opacity: 0.12;
    }

    .showroom-gateway-copy {
      position: absolute;
      z-index: 5;
      left: clamp(1.4rem, 4.2vw, 5rem);
      bottom: clamp(4.8rem, 8vw, 7rem);
      width: min(760px, calc(100% - 2rem));
      color: #f4f7fb;
    }

    .showroom-gateway-copy p {
      margin: 0 0 0.45rem;
      color: var(--accent);
      font-size: 0.86rem;
      font-weight: 900;
      letter-spacing: 0.18em;
    }

    .showroom-gateway-copy h1 {
      margin: 0;
      font-family: "Bebas Neue", sans-serif;
      font-size: clamp(5.6rem, 12vw, 13.5rem);
      line-height: 0.82;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .showroom-gateway-copy span {
      display: block;
      max-width: 560px;
      margin-top: 0.8rem;
      color: rgba(237, 243, 250, 0.82);
      font-size: clamp(1rem, 1.35vw, 1.18rem);
      line-height: 1.58;
    }

    .showroom-gateway-action {
      position: absolute;
      z-index: 6;
      right: clamp(1.4rem, 4vw, 4rem);
      bottom: clamp(1.4rem, 3vw, 2.8rem);
      min-height: 54px;
      border: 1px solid var(--accent);
      border-radius: 0.85rem;
      padding: 0.95rem 1.3rem;
      background: var(--accent);
      color: #02060b;
      font-size: 0.82rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    @media (max-width: 900px) {
      .showroom-gateway-door {
        transform: translateY(-3vh);
      }

      .showroom-gateway-main-door :global(.door-visual--portal .door-visual-image) {
        width: min(330px, 66vw);
      }

      .showroom-gateway-copy {
        bottom: 6.2rem;
      }

      .showroom-gateway-copy h1 {
        font-size: clamp(4.2rem, 17vw, 7rem);
      }

      .showroom-gateway-action {
        left: 1rem;
        right: auto;
      }
    }
  </style>
</section>
