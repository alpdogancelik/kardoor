<section class="quote-configurator" data-quote-config>
  <div class="quote-shell">
    <div class="quote-copy" data-reveal>
      <p class="kardoor-kicker">TEKLİF AKIŞI</p>

      <h2 class="kardoor-display" data-split>
        Kapınız için doğru modeli birlikte seçelim
      </h2>

      <p>
        Kullanım alanı, seri ve model tercihinize göre en uygun Kardoor çözümünü
        belirleyelim. Formu doldurun, proje ihtiyacınıza göre teklif sürecini başlatalım.
      </p>
    </div>

    <div class="quote-panel" data-reveal>
      <div class="quote-step">
        <p class="quote-step-index">1. Kullanım Alanı</p>
        <div class="quote-options">
          <button type="button">Villa</button>
          <button type="button">Apartman</button>
          <button type="button">Proje</button>
          <button type="button">Dış İklim</button>
        </div>
      </div>

      <div class="quote-step">
        <p class="quote-step-index">2. Seri Seçimi</p>
        <div class="quote-options">
          <button type="button">Alüminyum</button>
          <button type="button">Termo Wood</button>
          <button type="button">Kompozit</button>
          <button type="button">Laminoks</button>
        </div>
      </div>

      <div class="quote-step">
        <p class="quote-step-index">3. Model Seçimi</p>
        <div class="quote-options">
          <button type="button">K1001</button>
          <button type="button">K1051</button>
          <button type="button">K1101</button>
        </div>
      </div>

      <form class="quote-form">
        <p class="quote-step-index">4. Teklif Talebi</p>

        <label>
          Ad Soyad
          <input type="text" name="name" placeholder="Adınız Soyadınız" />
        </label>

        <label>
          Telefon
          <input type="tel" name="phone" placeholder="05xx xxx xx xx" />
        </label>

        <label>
          Şehir
          <input type="text" name="city" placeholder="Şehir" />
        </label>

        <label>
          Mesaj
          <textarea name="message" rows="4" placeholder="Proje detaylarınızı paylaşın"></textarea>
        </label>

        <button type="submit" class="btn btn-primary">
          Teklif Talep Et
        </button>
      </form>
    </div>
  </div>
</section>