<section class="quote-configurator" data-quote-config>
  <div class="quote-shell">
    <div class="section-intro" data-reveal>
      <p class="kardoor-kicker">Guided Quote</p>
      <h2 class="kardoor-display" data-split>Kapınız için doğru modeli birlikte seçelim</h2>
    </div>

    <div class="quote-grid">
      <article class="quote-step" data-reveal>
        <p class="quote-step-index">1. Kullanım Alanı</p>
        <ul>
          <li>Villa</li>
          <li>Apartman</li>
          <li>Proje</li>
          <li>Dış İklim</li>
        </ul>
      </article>

      <article class="quote-step" data-reveal>
        <p class="quote-step-index">2. Seri Seçimi</p>
        <ul>
          <li>Alüminyum</li>
          <li>Termo Wood</li>
          <li>Kompozit</li>
          <li>Laminoks</li>
        </ul>
      </article>

      <article class="quote-step" data-reveal>
        <p class="quote-step-index">3. Model Seçimi</p>
        <ul>
          <li>K1001</li>
          <li>K1051</li>
          <li>K1101</li>
        </ul>
      </article>

      <article class="quote-step quote-step--form" data-reveal>
        <p class="quote-step-index">4. Teklif Talebi</p>

        <label>
          Ad Soyad
          <input type="text" placeholder="Adınız Soyadınız" />
        </label>
        <label>
          Telefon
          <input type="tel" placeholder="05xx xxx xx xx" />
        </label>
        <label>
          Şehir
          <input type="text" placeholder="Şehir" />
        </label>
        <label>
          Mesaj
          <textarea rows="3" placeholder="Proje detaylarınızı paylaşın"></textarea>
        </label>

        <button type="button" class="btn btn-primary">Teklif Talep Et</button>
      </article>
    </div>
  </div>
</section>
