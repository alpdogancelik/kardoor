<section class="quote-showroom" data-quote-config>
  <div class="quote-showroom-bg" aria-hidden="true"></div>

  <div class="quote-showroom-shell">
    <div class="quote-showroom-copy" data-reveal>
      <p class="kardoor-kicker">TEKLİF AKIŞI</p>

      <h2 class="kardoor-display" data-split>
        Kapınız için doğru modeli birlikte seçelim
      </h2>

      <p>
        Kullanım alanı, seri ve model tercihinize göre en uygun Kardoor çözümünü
        belirleyelim. Girişiniz için doğru güvenlik, yüzey ve ölçü kombinasyonunu
        birlikte netleştirelim.
      </p>

      <div class="quote-value-list" aria-label="Teklif süreci avantajları">
        <div>
          <strong>01</strong>
          <span>Kullanım alanı analizi</span>
        </div>

        <div>
          <strong>02</strong>
          <span>Seri ve model yönlendirmesi</span>
        </div>

        <div>
          <strong>03</strong>
          <span>Proje odaklı teklif süreci</span>
        </div>
      </div>
    </div>

    <div class="quote-showroom-panel" data-reveal>
      <div class="quote-preview" aria-hidden="true">
        <div class="quote-preview-glow"></div>
        <div class="quote-preview-door">
          <span class="quote-door-line quote-door-line-left"></span>
          <span class="quote-door-line quote-door-line-center"></span>
          <span class="quote-door-handle"></span>
        </div>
      </div>

      <div class="quote-steps">
        <div class="quote-step-card">
          <p class="quote-step-label">1. Kullanım Alanı</p>

          <div class="quote-option-group">
            <button type="button" class="is-selected">Villa</button>
            <button type="button">Apartman</button>
            <button type="button">Proje</button>
            <button type="button">Dış İklim</button>
          </div>
        </div>

        <div class="quote-step-card">
          <p class="quote-step-label">2. Seri Seçimi</p>

          <div class="quote-option-group">
            <button type="button" class="is-selected">Alüminyum</button>
            <button type="button">Termo Wood</button>
            <button type="button">Kompozit</button>
            <button type="button">Laminoks</button>
          </div>
        </div>

        <div class="quote-step-card">
          <p class="quote-step-label">3. Model Seçimi</p>

          <div class="quote-option-group">
            <button type="button" class="is-selected">K1001</button>
            <button type="button">K1051</button>
            <button type="button">K1101</button>
          </div>
        </div>
      </div>

      <form class="quote-request-form">
        <p class="quote-step-label">4. Teklif Talebi</p>

        <div class="quote-form-grid">
          <label>
            Ad Soyad
            <input type="text" name="name" placeholder="Adınız Soyadınız" />
          </label>

          <label>
            Telefon
            <input type="tel" name="phone" placeholder="05xx xxx xx xx" />
          </label>

          <label>
            Şehir
            <input type="text" name="city" placeholder="Şehir" />
          </label>

          <label>
            Mesaj
            <textarea name="message" rows="4" placeholder="Proje detaylarınızı paylaşın"></textarea>
          </label>
        </div>

        <button type="submit" class="btn btn-primary quote-submit">
          Teklif Talep Et
        </button>
      </form>
    </div>
  </div>

  <style>
    .quote-showroom {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: clamp(5rem, 8vw, 8rem) 0;
      background:
        radial-gradient(circle at 76% 34%, rgba(44, 227, 255, 0.12), transparent 34%),
        linear-gradient(180deg, rgba(107, 114, 128, 0.08), transparent 44%),
        linear-gradient(180deg, #07111a 0%, #050b10 100%);
    }

    .quote-showroom-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(44, 227, 255, 0.04) 1px, transparent 1px),
        linear-gradient(180deg, rgba(44, 227, 255, 0.026) 1px, transparent 1px);
      background-size: 180px 180px;
      mask-image: radial-gradient(circle at 64% 48%, black, transparent 76%);
      opacity: 0.55;
    }

    .quote-showroom-shell {
      position: relative;
      z-index: 2;
      width: min(1240px, calc(100% - 2rem));
      margin-inline: auto;
      display: grid;
      grid-template-columns: minmax(0, 0.86fr) minmax(520px, 1.14fr);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
    }

    .quote-showroom-copy {
      max-width: 660px;
    }

    .quote-showroom-copy h2 {
      margin: 0.45rem 0 0;
      font-size: clamp(3.4rem, 6.8vw, 7rem);
      line-height: 0.9;
    }

    .quote-showroom-copy > p:not(.kardoor-kicker) {
      margin: 1rem 0 0;
      color: var(--text-muted);
      font-size: clamp(1rem, 1.35vw, 1.15rem);
      line-height: 1.72;
    }

    .quote-value-list {
      display: grid;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .quote-value-list div {
      border: 1px solid rgba(138, 166, 190, 0.22);
      border-radius: 8px;
      padding: 0.9rem 1rem;
      background: rgba(4, 10, 17, 0.52);
      backdrop-filter: blur(10px);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.75rem;
      align-items: center;
    }

    .quote-value-list strong {
      color: var(--accent);
      font-size: 0.86rem;
      letter-spacing: 0.12em;
    }

    .quote-value-list span {
      color: #dce8f3;
      font-size: 0.92rem;
      font-weight: 700;
    }

    .quote-showroom-panel {
      position: relative;
      border: 1px solid rgba(138, 166, 190, 0.26);
      border-radius: 8px;
      padding: clamp(1rem, 2.2vw, 1.5rem);
      overflow: hidden;
      background:
        radial-gradient(circle at 22% 20%, rgba(44, 227, 255, 0.12), transparent 32%),
        linear-gradient(160deg, rgba(12, 22, 34, 0.9), rgba(5, 10, 16, 0.94));
      box-shadow: 0 30px 90px rgba(0, 0, 0, 0.28);
    }

    .quote-showroom-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.05), transparent 22%, transparent 78%, rgba(255, 255, 255, 0.035)),
        linear-gradient(180deg, rgba(44, 227, 255, 0.05), transparent 42%);
      opacity: 0.85;
    }

    .quote-preview {
      position: relative;
      z-index: 2;
      min-height: 220px;
      border: 1px solid rgba(138, 166, 190, 0.18);
      border-radius: 8px;
      overflow: hidden;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 50% 72%, rgba(44, 227, 255, 0.12), transparent 38%),
        rgba(3, 8, 14, 0.52);
    }

    .quote-preview-glow {
      position: absolute;
      width: 420px;
      height: 420px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(44, 227, 255, 0.22), transparent 66%);
      filter: blur(26px);
    }

    .quote-preview-door {
      position: relative;
      width: 120px;
      height: 170px;
      border: 1px solid rgba(220, 232, 243, 0.18);
      border-radius: 0.65rem;
      background:
        linear-gradient(160deg, #263645, #111a24 56%, #071019);
      box-shadow:
        0 22px 50px rgba(0, 0, 0, 0.34),
        0 0 40px rgba(44, 227, 255, 0.1);
    }

    .quote-door-line {
      position: absolute;
      top: 28px;
      bottom: 24px;
      border-radius: 999px;
      background: rgba(44, 227, 255, 0.18);
    }

    .quote-door-line-left {
      left: 24px;
      width: 8px;
    }

    .quote-door-line-center {
      left: 48px;
      width: 5px;
      background: rgba(220, 232, 243, 0.16);
    }

    .quote-door-handle {
      position: absolute;
      top: 52px;
      right: 22px;
      width: 10px;
      height: 92px;
      border-radius: 999px;
      background: #dce8f3;
    }

    .quote-steps {
      position: relative;
      z-index: 2;
      display: grid;
      gap: 0.75rem;
      margin-top: 0.75rem;
    }

    .quote-step-card,
    .quote-request-form {
      border: 1px solid rgba(128, 153, 176, 0.22);
      border-radius: 8px;
      padding: 1rem;
      background: rgba(4, 9, 15, 0.56);
      backdrop-filter: blur(10px);
    }

    .quote-step-label {
      margin: 0;
      color: var(--accent);
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.13em;
      text-transform: uppercase;
    }

    .quote-option-group {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.75rem;
    }

    .quote-option-group button {
      border: 1px solid rgba(170, 190, 210, 0.28);
      border-radius: 999px;
      padding: 0.5rem 0.75rem;
      background: rgba(6, 12, 20, 0.85);
      color: #dce8f3;
      cursor: pointer;
      transition:
        border-color 180ms ease,
        background 180ms ease,
        transform 180ms ease;
    }

    .quote-option-group button:hover,
    .quote-option-group button.is-selected {
      border-color: rgba(44, 227, 255, 0.72);
      background: rgba(44, 227, 255, 0.12);
      transform: translateY(-1px);
    }

    .quote-request-form {
      position: relative;
      z-index: 2;
      margin-top: 0.75rem;
    }

    .quote-form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.7rem;
      margin-top: 0.85rem;
    }

    .quote-form-grid label {
      display: grid;
      gap: 0.35rem;
      color: #dce8f4;
      font-size: 0.88rem;
      font-weight: 700;
    }

    .quote-form-grid label:last-child {
      grid-column: 1 / -1;
    }

    .quote-form-grid input,
    .quote-form-grid textarea {
      width: 100%;
      border: 1px solid rgba(135, 160, 183, 0.35);
      border-radius: 8px;
      padding: 0.78rem 0.85rem;
      background: rgba(5, 10, 16, 0.86);
      color: white;
      resize: vertical;
    }

    .quote-form-grid input:focus,
    .quote-form-grid textarea:focus {
      outline: 2px solid rgba(44, 227, 255, 0.26);
      outline-offset: 1px;
    }

    .quote-submit {
      width: 100%;
      margin-top: 0.8rem;
    }

    @media (max-width: 1023px) {
      .quote-showroom-shell {
        grid-template-columns: 1fr;
      }

      .quote-showroom-copy {
        max-width: 780px;
      }
    }

    @media (max-width: 760px) {
      .quote-showroom-shell {
        width: min(100% - 1rem, 1240px);
      }

      .quote-showroom-copy h2 {
        font-size: clamp(3rem, 16vw, 4.8rem);
      }

      .quote-showroom-panel {
        padding: 0.85rem;
        border-radius: 8px;
      }

      .quote-form-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>
