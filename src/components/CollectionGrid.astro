---
import { collections } from "../data/collections";
---

<section class="section-shell">
  <div class="site-container space-y-8">
    <div class="space-y-3" data-reveal>
      <p class="kardoor-kicker">Koleksiyonlar</p>
      <h2 class="kardoor-display text-4xl text-white sm:text-5xl">Tarzınıza Göre Seri Seçimi</h2>
      <p class="max-w-2xl text-slate-300">
        Mimari dile ve kullanım senaryosuna göre şekillenen koleksiyonlarımızla projeniz için doğru kapıyı hızlıca belirleyin.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        collections.map((collection, index) => (
          <article class="panel min-h-28 p-5" data-reveal data-reveal-delay={String(index * 0.05)}>
            <p class="text-sm uppercase tracking-[0.12em] text-accent-400">Collection {index + 1}</p>
            <h3 class="mt-3 text-2xl font-semibold text-white">{collection}</h3>
          </article>
        ))
      }
    </div>
  </div>
</section>
