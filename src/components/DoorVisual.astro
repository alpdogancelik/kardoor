---
interface Props {
  image?: string;
  alt: string;
  size?: "portal" | "room" | "spotlight";
  className?: string;
}

const {
  image = "/images/doors/door-midnight.svg",
  alt,
  size = "room",
  className = ""
} = Astro.props;

const loading = size === "portal" ? "eager" : "lazy";
const fetchPriority = size === "portal" ? "high" : "auto";
---

<div class:list={["door-visual-wrap", `door-visual--${size}`, className]}>
  <div class="door-visual-floor-shadow" aria-hidden="true"></div>

  <img
    src={image}
    alt={alt}
    class="door-visual-image"
    loading={loading}
    fetchpriority={fetchPriority}
  />

  <img
    src={image}
    alt=""
    aria-hidden="true"
    class="door-visual-reflection"
    loading="lazy"
  />
</div>