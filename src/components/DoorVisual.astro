---
interface Props {
  image?: string;
  alt: string;
  size?: "portal" | "room" | "spotlight";
  className?: string;
}

const {
  image = "/images/doors/door-midnight.svg",
  alt,
  size = "room",
  className = ""
} = Astro.props;

const loading = size === "portal" ? "eager" : "lazy";
const fetchPriority = size === "portal" ? "high" : "auto";
---

<div class:list={["door-visual", `door-visual--${size}`, className]}>
  <div class="door-visual-aura" aria-hidden="true"></div>
  <div class="door-visual-floor-shadow" aria-hidden="true"></div>

  <div class="door-visual-frame">
    <div class="door-visual-inner-glow" aria-hidden="true"></div>

    <img
      src={image}
      alt={alt}
      class="door-visual-image"
      loading={loading}
      fetchpriority={fetchPriority}
      decoding="async"
    />
  </div>

  <div class="door-visual-reflection-wrap" aria-hidden="true">
    <img
      src={image}
      alt=""
      class="door-visual-reflection"
      loading="lazy"
      decoding="async"
    />
  </div>
</div>

<style>
  .door-visual {
    --frame-radius: 28px;
    --frame-padding: 18px;
    --frame-max-width: 520px;
    --frame-height: 720px;
    --glow-color: rgba(33, 203, 255, 0.22);
    --glow-color-soft: rgba(33, 203, 255, 0.12);
    --frame-bg-top: rgba(10, 22, 38, 0.96);
    --frame-bg-bottom: rgba(4, 10, 20, 0.96);
    --frame-border: rgba(111, 169, 255, 0.14);
    --inner-border: rgba(255, 255, 255, 0.04);
    --shadow-strong: 0 28px 70px rgba(0, 0, 0, 0.42);
    --shadow-soft: 0 14px 28px rgba(0, 0, 0, 0.24);

    position: relative;
    width: min(100%, var(--frame-max-width));
    margin-inline: auto;
    isolation: isolate;
  }

  .door-visual-aura {
    position: absolute;
    inset: 8% -8% 18%;
    z-index: 0;
    background:
      radial-gradient(circle at 50% 45%, var(--glow-color) 0%, transparent 42%),
      radial-gradient(circle at 50% 70%, var(--glow-color-soft) 0%, transparent 52%);
    filter: blur(10px);
    pointer-events: none;
  }

  .door-visual-floor-shadow {
    position: absolute;
    left: 50%;
    bottom: 2%;
    transform: translateX(-50%);
    width: 72%;
    height: 34px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(0, 0, 0, 0.44) 0%, rgba(0, 0, 0, 0.08) 62%, transparent 100%);
    filter: blur(10px);
    z-index: 0;
    pointer-events: none;
  }

  .door-visual-frame {
    position: relative;
    z-index: 2;
    width: 100%;
    min-height: var(--frame-height);
    padding: var(--frame-padding);
    border-radius: var(--frame-radius);
    border: 1px solid var(--frame-border);
    background:
      linear-gradient(180deg, var(--frame-bg-top) 0%, var(--frame-bg-bottom) 100%);
    box-shadow:
      var(--shadow-strong),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    overflow: hidden;
  }

  .door-visual-frame::before {
    content: "";
    position: absolute;
    inset: 10px;
    border-radius: calc(var(--frame-radius) - 10px);
    border: 1px solid var(--inner-border);
    pointer-events: none;
  }

  .door-visual-inner-glow {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(61, 150, 255, 0.08) 0%, transparent 24%),
      radial-gradient(circle at 50% 30%, rgba(56, 214, 255, 0.1) 0%, transparent 35%);
    pointer-events: none;
  }

  .door-visual-image {
    position: relative;
    z-index: 2;
    display: block;
    width: 100%;
    height: 100%;
    max-height: calc(var(--frame-height) - (var(--frame-padding) * 2));
    object-fit: contain;
    object-position: center center;
    filter:
      drop-shadow(0 24px 38px rgba(0, 0, 0, 0.42))
      drop-shadow(0 0 20px rgba(30, 180, 255, 0.08));
    user-select: none;
    -webkit-user-drag: none;
  }

  .door-visual-reflection-wrap {
    position: absolute;
    left: 50%;
    bottom: -10%;
    z-index: 1;
    width: 78%;
    height: 32%;
    transform: translateX(-50%);
    overflow: hidden;
    mask-image: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0.08) 32%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0.08) 32%,
      transparent 100%
    );
    pointer-events: none;
  }

  .door-visual-reflection {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top center;
    transform: scaleY(-1);
    opacity: 0.18;
    filter: blur(1px);
  }

  .door-visual--portal {
    --frame-max-width: 560px;
    --frame-height: 780px;
    --frame-radius: 32px;
    --frame-padding: 20px;
  }

  .door-visual--room {
    --frame-max-width: 460px;
    --frame-height: 650px;
    --frame-radius: 26px;
    --frame-padding: 18px;
  }

  .door-visual--spotlight {
    --frame-max-width: 360px;
    --frame-height: 520px;
    --frame-radius: 22px;
    --frame-padding: 14px;
  }

  @media (max-width: 900px) {
    .door-visual--portal {
      --frame-height: 680px;
      --frame-max-width: 500px;
    }

    .door-visual--room {
      --frame-height: 590px;
    }
  }

  @media (max-width: 640px) {
    .door-visual {
      --frame-radius: 22px;
      --frame-padding: 14px;
    }

    .door-visual--portal {
      --frame-height: 560px;
      --frame-max-width: 100%;
    }

    .door-visual--room {
      --frame-height: 500px;
      --frame-max-width: 100%;
    }

    .door-visual--spotlight {
      --frame-height: 420px;
      --frame-max-width: 100%;
    }

    .door-visual-reflection-wrap {
      width: 86%;
      height: 26%;
      bottom: -7%;
    }
  }
</style>