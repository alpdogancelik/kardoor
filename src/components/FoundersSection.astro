      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 6px;
      background: #d7dee8;
    }

    .kd-founder-image img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      filter: grayscale(1) contrast(1.05);
      transition:
        transform 0.8s ease,
        filter 0.8s ease;
    }

    .kd-founder-image::after {
      content: "";
      position: absolute;
      inset: -45%;
      z-index: 4;
      pointer-events: none;
      opacity: 0;
      background: linear-gradient(
        115deg,
        transparent 0%,
        transparent 42%,
        rgba(255, 255, 255, 0.18) 47%,
        rgba(255, 255, 255, 0.42) 50%,
        rgba(150, 178, 232, 0.18) 53%,
        transparent 60%,
        transparent 100%
      );
      transform: translateX(-35%);
      transition:
        opacity 0.35s ease,
        transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .kd-founder-card:hover .kd-founder-image::after {
      opacity: 1;
      transform: translateX(35%);
