---
const navItems = [
  { href: "/", label: "Ana Sayfa" },
  { href: "/koleksiyonlar", label: "Koleksiyonlar" },
  { href: "/urunler", label: "Ürünler" },
  { href: "/teklif", label: "Teklif Al" },
  { href: "/iletisim", label: "İletişim" }
];

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-header">
  <div class="site-header-shell">
    <div class="site-brand-panel">
      <a href="/" class="site-logo" aria-label="Kardoor ana sayfa">
        <span class="site-logo-text">kar<span>door</span></span>
      </a>

      <a href="/koleksiyonlar" class="site-menu-button">
        <span aria-hidden="true"></span>
        Menu
      </a>
    </div>

    <div class="site-actions">
      <a href="/iletisim" class="site-action-pill site-action-pill-primary">
        <span aria-hidden="true"></span>
        İletişim
      </a>

      <a href="/urunler" class="site-action-pill site-action-pill-secondary">
        <span aria-hidden="true"></span>
        Katalog
      </a>
    </div>
  </div>

  <nav class="site-nav" aria-label="Ana navigasyon">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          "site-nav-link",
          { "is-active": isActive(item.href) }
        ]}
        aria-current={isActive(item.href) ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 80;
    padding: 6px 14px 8px;
    background: #000;
  }

  .site-header-shell {
    max-width: 100%;
    margin: 0 auto;
    min-height: 66px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-brand-panel {
    width: min(560px, 45vw);
    min-height: 64px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-radius: 14px;
    padding: 0 16px;
    background: linear-gradient(180deg, #22272c, #1a1d20);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .site-logo-text {
    color: #f5f7f8;
    font-size: clamp(2rem, 3.05vw, 3.15rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    text-transform: lowercase;
  }

  .site-logo-text span {
    color: #fff04d;
  }

  .site-menu-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #ffffff;
    font-size: 0.92rem;
    font-weight: 900;
    line-height: 1;
  }

  .site-menu-button span {
    position: relative;
    width: 22px;
    height: 14px;
    display: inline-block;
    border-top: 2px solid currentColor;
  }

  .site-menu-button span::before,
  .site-menu-button span::after {
    content: "";
    position: absolute;
    right: 0;
    height: 2px;
    background: currentColor;
  }

  .site-menu-button span::before {
    top: 5px;
    width: 16px;
  }

  .site-menu-button span::after {
    top: 12px;
    width: 8px;
  }

  .site-nav {
    position: absolute;
    left: 50%;
    top: calc(100% + 6px);
    z-index: 2;
    display: none;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    padding: 0.35rem;
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(14px);
  }

  .site-nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 13px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .site-nav-link:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-1px);
  }

  .site-nav-link.is-active {
    color: #090909;
    background: #fff04d;
    border-color: #fff04d;
  }

  .site-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .site-action-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 52px;
    border-radius: 14px;
    padding: 0 1.35rem;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition:
      transform 180ms ease,
      filter 180ms ease,
      border-color 180ms ease;
  }

  .site-action-pill:hover {
    transform: translateY(-2px);
    filter: brightness(1.03);
  }

  .site-action-pill span {
    width: 38px;
    height: 20px;
    flex: 0 0 auto;
  }

  .site-action-pill-primary {
    color: #090909;
    background: #fff04d;
  }

  .site-action-pill-primary span {
    border: 5px solid #131313;
    border-right-width: 16px;
    border-radius: 999px;
    box-shadow: inset 0 0 0 5px #fff04d;
  }

  .site-action-pill-secondary {
    border: 1px solid rgba(255, 255, 255, 0.76);
    color: #ffffff;
    background: #080808;
  }

  .site-action-pill-secondary span {
    position: relative;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.84);
    border-radius: 10px;
  }

  .site-action-pill-secondary span::after {
    content: "";
    position: absolute;
    inset: 8px 12px;
    border-radius: 999px;
    background: #ffffff;
  }

  @media (max-width: 1024px) {
    .site-brand-panel {
      width: min(520px, 56vw);
    }

    .site-action-pill {
      padding-inline: 1rem;
    }

    .site-action-pill-secondary {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .site-header {
      padding: 8px;
    }

    .site-header-shell {
      min-height: 60px;
    }

    .site-brand-panel {
      width: auto;
      min-height: 60px;
      flex: 1;
      padding-inline: 12px;
      border-radius: 13px;
    }

    .site-logo-text {
      font-size: clamp(1.8rem, 9vw, 2.5rem);
    }

    .site-menu-button {
      font-size: 0.9rem;
    }

    .site-actions {
      display: none;
    }
  }
</style>
