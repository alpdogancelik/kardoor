---
const navItems = [
  { href: "/", label: "Ana Sayfa" },
  { href: "/koleksiyonlar", label: "Koleksiyonlar" },
  { href: "/urunler", label: "Ürünler" },
  { href: "/teklif", label: "Teklif Al" },
  { href: "/iletisim", label: "İletişim" }
];
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-logo">KARDOOR</a>

    <nav class="site-nav" aria-label="Ana navigasyon">
      {
        navItems.map((item) => (
          <a href={item.href} class="site-nav-link">
            {item.label}
          </a>
        ))
      }
    </nav>

    <a href="/teklif" class="btn btn-primary site-header-cta">Teklif Al</a>
  </div>
</header>
