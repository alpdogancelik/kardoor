---
const navItems = [
  { href: "/", label: "Ana Sayfa" },
  { href: "/koleksiyonlar", label: "Koleksiyonlar" },
  { href: "/urunler", label: "Ürünler" },
  { href: "/teklif", label: "Teklif Al" },
  { href: "/iletisim", label: "İletişim" }
];

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-header">
  <div class="site-header-shell">
    <a href="/" class="site-logo" aria-label="Ege Kardoor ana sayfa">
      <span class="site-logo-mark" aria-hidden="true">
        <span class="site-logo-mark-left"></span>
        <span class="site-logo-mark-right"></span>
        <span class="site-logo-mark-core"></span>
      </span>

      <span class="site-logo-copy">
        <span class="site-logo-title"><strong>EGE</strong> KARDOOR</span>
        <span class="site-logo-tagline">Steel Doors · Secured Futures</span>
      </span>
    </a>

    <div class="site-actions">
      <a href="/iletisim" class="site-action-pill site-action-pill-primary">
        İletişim
      </a>

      <a href="/urunler" class="site-action-pill site-action-pill-secondary">
        Katalog
      </a>
    </div>
  </div>

  <nav class="site-nav" aria-label="Ana navigasyon">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          "site-nav-link",
          { "is-active": isActive(item.href) }
        ]}
        aria-current={isActive(item.href) ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 80;
    border-bottom: 1px solid rgba(15, 23, 42, 0.1);
    background: rgba(247, 249, 252, 0.92);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(18px);
  }

  .site-header-shell {
    width: min(1440px, calc(100% - 2rem));
    margin: 0 auto;
    min-height: calc(var(--header-height) - 38px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: #0f172a;
    text-decoration: none;
  }

  .site-logo-mark {
    position: relative;
    width: 48px;
    height: 58px;
    flex: 0 0 auto;
  }

  .site-logo-mark-left,
  .site-logo-mark-right,
  .site-logo-mark-core {
    position: absolute;
    display: block;
  }

  .site-logo-mark-left {
    left: 0;
    top: 5px;
    width: 24px;
    height: 48px;
    background: linear-gradient(180deg, #0066ff 0%, #0985ff 100%);
    clip-path: polygon(0 18%, 100% 0, 100% 32%, 55% 46%, 55% 100%, 0 72%);
  }

  .site-logo-mark-right {
    right: 0;
    top: 5px;
    width: 24px;
    height: 48px;
    background: linear-gradient(180deg, #00309b 0%, #07172a 100%);
    clip-path: polygon(0 0, 100% 18%, 100% 72%, 45% 100%, 45% 46%, 0 32%);
  }

  .site-logo-mark-core {
    left: 20px;
    bottom: 0;
    width: 13px;
    height: 38px;
    background: linear-gradient(180deg, #0044cb 0%, #061c56 100%);
    clip-path: polygon(0 37%, 100% 20%, 100% 100%, 0 78%);
  }

  .site-logo-copy {
    display: grid;
    gap: 0.3rem;
  }

  .site-logo-title {
    color: #0f172a;
    font-size: clamp(1.08rem, 1.8vw, 1.62rem);
    font-weight: 800;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .site-logo-title strong {
    color: #00309b;
    font-weight: 900;
  }

  .site-logo-tagline {
    color: #6b7280;
    font-size: clamp(0.52rem, 0.72vw, 0.66rem);
    font-weight: 800;
    letter-spacing: 0.28em;
    line-height: 1;
    text-transform: uppercase;
  }

  .site-nav {
    width: min(1440px, calc(100% - 2rem));
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.6vw, 2.3rem);
    min-height: 38px;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }

  .site-nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0;
    color: #4b5563;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      color 180ms ease,
      transform 180ms ease;
    white-space: nowrap;
  }

  .site-nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
    background: #0066ff;
    transition: transform 180ms ease;
  }

  .site-nav-link:hover {
    color: #00309b;
    transform: translateY(-1px);
  }

  .site-nav-link.is-active {
    color: #00309b;
  }

  .site-nav-link.is-active::after,
  .site-nav-link:hover::after {
    transform: scaleX(1);
  }

  .site-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .site-action-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    border-radius: 8px;
    padding: 0 1.35rem;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .site-action-pill:hover {
    transform: translateY(-1px);
  }

  .site-action-pill-primary {
    color: #ffffff;
    background: linear-gradient(135deg, #0066ff 0%, #00309b 100%);
    box-shadow: 0 14px 28px rgba(0, 48, 155, 0.18);
  }

  .site-action-pill-secondary {
    border: 1px solid rgba(15, 23, 42, 0.2);
    color: #0f172a;
    background: rgba(255, 255, 255, 0.68);
  }

  @media (max-width: 1024px) {
    .site-action-pill {
      padding-inline: 1rem;
    }

    .site-action-pill-secondary {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .site-header {
      padding: 0;
    }

    .site-header-shell {
      width: min(100% - 1rem, 1440px);
      min-height: calc(var(--header-height) - 38px);
    }

    .site-logo-mark {
      width: 38px;
      height: 46px;
    }

    .site-logo-mark-left,
    .site-logo-mark-right {
      width: 19px;
      height: 38px;
    }

    .site-logo-mark-core {
      left: 16px;
      width: 10px;
      height: 30px;
    }

    .site-logo-title {
      font-size: clamp(0.9rem, 4.3vw, 1.15rem);
      letter-spacing: 0.12em;
    }

    .site-logo-tagline {
      display: none;
    }

    .site-actions {
      display: none;
    }

    .site-nav {
      width: min(100% - 1rem, 1440px);
      gap: 0.95rem;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .site-nav::-webkit-scrollbar {
      display: none;
    }

    .site-nav-link {
      font-size: 0.66rem;
      letter-spacing: 0.12em;
    }
  }
</style>
