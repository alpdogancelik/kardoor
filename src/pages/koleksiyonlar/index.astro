---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collections } from "../../data/collections";
import { getProductsByCollectionSlug } from "../../data/catalog";
---

<BaseLayout
  title="Koleksiyonlar | Kardoor Çelik Kapı"
  description="Kardoor premium çelik kapı koleksiyonlarını seri bazında keşfedin."
>
  <section class="subpage-wrap">
    <div class="subpage-head" data-reveal>
      <p class="kardoor-kicker">Koleksiyonlar</p>
      <h1 class="kardoor-display">Kardoor Showroom Serileri</h1>
      <p>Her seri, farklı mimari dil ve kullanım ihtiyacı için konumlandırılmış premium giriş çözümüdür.</p>
    </div>

    <div class="subpage-list">
      {
        collections.map((collection) => {
          const count = getProductsByCollectionSlug(collection.slug).length;

          return (
            <article class="subpage-card" data-reveal>
              <div>
                <p class="subpage-number">{collection.number}</p>
                <h2 class="kardoor-display">{collection.title}</h2>
                <p>{collection.description}</p>
                <p class="subpage-meta">{count} model</p>
              </div>

              <div class="subpage-actions">
                <a href={`/koleksiyonlar/${collection.slug}`} class="btn btn-primary">Seriyi İncele</a>
                <a href="/teklif" class="btn btn-secondary">Teklif Al</a>
              </div>
            </article>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
