---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="İletişim | Kardoor" description="Kardoor satış ve proje ekibiyle iletişime geçin.">
  <section class="subpage-wrap">
    <div class="subpage-head" data-reveal>
      <p class="kardoor-kicker">İletişim</p>
      <h1 class="kardoor-display">Kardoor Ekibiyle Görüşün</h1>
      <p>Showroom randevusu, model danışmanlığı ve proje desteği için bize ulaşın.</p>
    </div>

    <div class="subpage-list subpage-list--grid">
      <article class="subpage-card" data-reveal>
        <p class="subpage-number">Telefon</p>
        <h2>+90 5XX XXX XX XX</h2>
      </article>
      <article class="subpage-card" data-reveal>
        <p class="subpage-number">E-Posta</p>
        <h2>info@kardoor.com</h2>
      </article>
      <article class="subpage-card" data-reveal>
        <p class="subpage-number">Showroom</p>
        <h2>İstanbul / Türkiye</h2>
      </article>
    </div>
  </section>
</BaseLayout>
