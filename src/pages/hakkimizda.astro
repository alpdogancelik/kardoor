---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Hakkımızda | Kardoor" description="Kardoor marka yaklaşımı ve üretim vizyonu.">
  <section class="section-shell">
    <div class="site-container">
      <div class="panel mx-auto max-w-4xl space-y-6 p-6 sm:p-10" data-reveal>
        <p class="kardoor-kicker">Hakkımızda</p>
        <h1 class="kardoor-display text-5xl text-white sm:text-6xl">Kardoor Premium Door Studio</h1>
        <p class="text-lg leading-relaxed text-slate-300">
          Kardoor, güvenlik standardını yükselten ve mimari estetiği merkeze alan premium çelik kapı çözümleri üretir.
          Her modelimiz; teknik dayanım, yalıtım performansı ve yüzey kalitesi odağında geliştirilir.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
