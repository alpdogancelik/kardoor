---
import BaseLayout from "../layouts/BaseLayout.astro";
import EntrancePortal from "../components/EntrancePortal.astro";
import DoorOpeningTransition from "../components/DoorOpeningTransition.astro";
import ShowroomCorridor from "../components/ShowroomCorridor.astro";
import CollectionWalk from "../components/CollectionWalk.astro";
import FeaturedModelSpotlight from "../components/FeaturedModelSpotlight.astro";
import QuoteConfigurator from "../components/QuoteConfigurator.astro";
---

<BaseLayout
  title="Kardoor Showroom | Premium Çelik Kapı Deneyimi"
  description="Kardoor premium çelik kapı koleksiyonlarını kapıdan içeri girilen immersive showroom deneyimiyle keşfedin."
>
  <EntrancePortal />
  <DoorOpeningTransition />
  <ShowroomCorridor />
  <CollectionWalk />
  <FeaturedModelSpotlight />
  <QuoteConfigurator />
</BaseLayout>
