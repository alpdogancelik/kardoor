---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products } from "../../data/products";
---

<BaseLayout title="Ürünler | Kardoor" description="Kardoor model kodlarına göre ürün detaylarını inceleyin.">
  <section class="subpage-wrap">
    <div class="subpage-head" data-reveal>
      <p class="kardoor-kicker">Ürünler</p>
      <h1 class="kardoor-display">Model Arşivi</h1>
      <p>Koleksiyonlardan öne çıkan model kodlarını seçerek teknik detay sayfalarına geçebilirsiniz.</p>
    </div>

    <div class="subpage-list subpage-list--grid">
      {
        products.map((product) => (
          <article class="subpage-card" data-reveal>
            <p class="subpage-number">{product.code}</p>
            <h2>{product.collection}</h2>
            <p>{product.shortDescription}</p>
            <div class="subpage-actions">
              <a href={`/urunler/${product.slug}`} class="btn btn-secondary">Detayları Gör</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
