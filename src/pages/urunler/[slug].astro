---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products, type Product } from "../../data/products";
import DoorVisual from "../../components/DoorVisual.astro";

interface Props {
  product: Product;
}

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

const similar = products
  .filter((item) => item.slug !== product.slug && item.collectionSlug === product.collectionSlug)
  .concat(products.filter((item) => item.slug !== product.slug && item.collectionSlug !== product.collectionSlug))
  .slice(0, 3);
---

<BaseLayout title={`${product.code} | Kardoor`} description={product.shortDescription}>
  <section class="subpage-wrap">
    <div class="subpage-head" data-reveal>
      <a href={`/koleksiyonlar/${product.collectionSlug}`} class="back-link">← {product.collection} sayfasına dön</a>
      <p class="kardoor-kicker">{product.collection}</p>
      <h1 class="kardoor-display">{product.code}</h1>
      <p>{product.shortDescription}</p>
    </div>

    <div class="product-detail-stage" data-reveal>
      <DoorVisual image={product.image} alt={product.title} size="spotlight" />

      <div class="product-detail-content">
        <h2>{product.title}</h2>

        <ul class="featured-specs">
          {product.specs.map((spec) => <li>{spec}</li>)}
        </ul>

        <h3>Malzemeler</h3>
        <ul class="bullet-list">
          {product.materials.map((material) => <li>{material}</li>)}
        </ul>

        <h3>Kullanım Alanları</h3>
        <ul class="bullet-list">
          {product.usageAreas.map((area) => <li>{area}</li>)}
        </ul>

        <div class="subpage-actions">
          <a href="/teklif" class="btn btn-primary">Teklif Al</a>
          <a href="/iletisim" class="btn btn-secondary">İletişim</a>
        </div>
      </div>
    </div>

    <div class="subpage-list subpage-list--grid">
      {
        similar.map((item) => (
          <article class="subpage-card" data-reveal>
            <p class="subpage-number">{item.code}</p>
            <h3>{item.collection}</h3>
            <p>{item.shortDescription}</p>
            <div class="subpage-actions">
              <a href={`/urunler/${item.slug}`} class="btn btn-secondary">Detayları Gör</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
