---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products, type Product } from "../../data/products";

interface Props {
  product: Product;
}

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

const similarProducts = products
  .filter((item) => item.slug !== product.slug && item.collection === product.collection)
  .concat(products.filter((item) => item.slug !== product.slug && item.collection !== product.collection))
  .slice(0, 3);

const specLabels: Record<keyof Product["specs"], string> = {
  panelThickness: "Panel Kalınlığı",
  lockSystem: "Kilit Sistemi",
  insulation: "Yalıtım",
  hinge: "Menteşe",
  coating: "Yüzey Kaplama"
};
---

<BaseLayout title={`${product.name} | Kardoor`} description={product.description}>
  <section class="section-shell">
    <div class="site-container space-y-8">
      <a href="/urunler" class="inline-flex items-center text-sm text-accent-400 transition hover:text-accent-300" data-reveal>
        ← Tüm ürünlere dön
      </a>

      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="panel overflow-hidden" data-reveal>
          <img src={product.gallery[0]} alt={product.name} class="h-[430px] w-full object-cover" loading="eager" />
        </div>

        <div class="panel space-y-6 p-6 sm:p-8" data-reveal data-reveal-delay="0.08">
          <p class="kardoor-kicker">{product.collection}</p>
          <h1 class="kardoor-display text-5xl text-white sm:text-6xl">{product.name}</h1>
          <p class="text-slate-300">{product.description}</p>

          <div class="flex flex-wrap gap-3">
            <a href="/iletisim" class="btn btn-primary">Teklif Al</a>
            <a href="https://wa.me/905000000000" class="btn btn-secondary">WhatsApp</a>
          </div>
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <article class="panel p-6 sm:p-8" data-reveal>
          <h2 class="text-2xl font-semibold text-white">Teknik Özellikler</h2>
          <ul class="mt-5 space-y-3">
            {
              (Object.entries(product.specs) as [keyof Product["specs"], string][]).map(([key, value]) => (
                <li class="flex items-start justify-between gap-4 border-b border-white/10 pb-3 text-sm text-slate-300">
                  <span>{specLabels[key]}</span>
                  <strong class="text-right text-white">{value}</strong>
                </li>
              ))
            }
          </ul>
        </article>

        <article class="panel p-6 sm:p-8" data-reveal data-reveal-delay="0.08">
          <h2 class="text-2xl font-semibold text-white">Yüzey ve Kullanım Alanları</h2>
          <div class="mt-5 grid gap-6 sm:grid-cols-2">
            <div>
              <h3 class="text-sm uppercase tracking-[0.14em] text-accent-400">Yüzey Seçenekleri</h3>
              <ul class="mt-3 space-y-2 text-sm text-slate-300">
                {product.surfaces.map((surface) => <li>• {surface}</li>)}
              </ul>
            </div>
            <div>
              <h3 class="text-sm uppercase tracking-[0.14em] text-accent-400">Kullanım Alanları</h3>
              <ul class="mt-3 space-y-2 text-sm text-slate-300">
                {product.usageAreas.map((area) => <li>• {area}</li>)}
              </ul>
            </div>
          </div>
        </article>
      </div>

      <div class="space-y-4" data-reveal>
        <h2 class="text-2xl font-semibold text-white">Galeri</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {product.gallery.map((image, index) => (
            <div class="panel overflow-hidden" data-reveal data-reveal-delay={String(index * 0.04)}>
              <img src={image} alt={`${product.name} galeri ${index + 1}`} class="h-56 w-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <div class="space-y-4" data-reveal>
        <h2 class="text-2xl font-semibold text-white">Benzer Ürünler</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {
            similarProducts.map((item) => (
              <a href={`/urunler/${item.slug}`} class="panel group overflow-hidden transition hover:-translate-y-1">
                <img src={item.image} alt={item.name} class="h-40 w-full object-cover" loading="lazy" />
                <div class="space-y-2 p-4">
                  <p class="text-xs uppercase tracking-[0.14em] text-accent-400">{item.collection}</p>
                  <h3 class="text-xl text-white">{item.name}</h3>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
