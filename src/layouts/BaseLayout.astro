---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kardoor | Premium Celik Kapi Showroomu",
  description = "Kardoor premium celik ve giris kapilarinda guvenlik, tasarim ve ozel uretimi bir araya getirir."
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05080f" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { initLenis } from "../scripts/lenis";
      import { initGsapReveals } from "../scripts/gsap-reveals";

      const boot = () => {
        initLenis();
        initGsapReveals();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot, { once: true });
      } else {
        boot();
      }
    </script>
  </body>
</html>
